<?xml version="1.0" encoding="utf-8"?>
<!--
  This publish profile produces a framework-dependent deployment to bin\publish.
  It does NOT hard-code a RuntimeIdentifier so the default restore assets are used,
  which avoids the NETSDK1005 "doesn't have a target for net8.0" error on VS Publish.

  To publish from the command line:
      dotnet publish src/IQFlowAgent.Web/IQFlowAgent.Web.csproj -p:PublishProfile=FolderPublish

  To publish from Visual Studio:
      Right-click project → Publish → Import Profile → select this file
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <PublishProvider>FileSystem</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <PublishUrl>bin\publish</PublishUrl>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <!-- Framework-dependent: requires .NET 8 runtime on the target server -->
    <SelfContained>false</SelfContained>
    <!-- No RuntimeIdentifier here — avoids triggering a RID-specific restore -->
    <Configuration>Release</Configuration>
    <TargetFramework>net8.0</TargetFramework>
    <ProjectGuid>00000000-0000-0000-0000-000000000000</ProjectGuid>
  </PropertyGroup>
  <!-- Preserve the SQLite database and user-uploaded files across re-deployments.
       DeleteExistingFiles=true would otherwise wipe these on every publish. -->
  <ItemGroup>
    <MsDeploySkipRules Include="SkipAppData">
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>App_Data</AbsolutePath>
    </MsDeploySkipRules>
    <MsDeploySkipRules Include="SkipUploads">
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>wwwroot\\uploads</AbsolutePath>
    </MsDeploySkipRules>
    <MsDeploySkipRules Include="SkipReports">
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>wwwroot\\reports</AbsolutePath>
    </MsDeploySkipRules>
  </ItemGroup>
</Project>
