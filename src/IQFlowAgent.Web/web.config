<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config for IIS / Azure App Service hosting.

  When this application is published with `dotnet publish`, the ASP.NET Core SDK
  automatically transforms the <aspNetCore> element below, replacing the
  %LAUNCHER_PATH% / %LAUNCHER_ARGS% tokens with the correct values for the
  target deployment (framework-dependent or self-contained).

  The <requestFiltering> section overrides IIS's built-in request-body size
  limit.  IIS defaults to 30,000,000 bytes (~28.6 MB); without this entry any
  upload larger than that is rejected with HTTP 413 ("The page was not
  displayed because the request entity is too large") before the request even
  reaches the ASP.NET Core / Kestrel layer.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>

      <!-- Route every request through the ASP.NET Core Module v2 -->
      <handlers>
        <add name="aspNetCore" path="*" verb="*"
             modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <!--
        processPath / arguments are replaced by the publish transform.
        hostingModel="inprocess" gives the best performance on IIS/Azure App Service.
      -->
      <aspNetCore processPath="%LAUNCHER_PATH%" arguments="%LAUNCHER_ARGS%"
                  stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess" />

      <security>
        <requestFiltering>
          <!--
            Raise the IIS request-body size limit to 250 MB to match the value
            configured in AppConstants.MaxUploadBytes (262,144,000 bytes).

            250 MB  =  250 × 1,048,576  =  262,144,000 bytes
          -->
          <requestLimits maxAllowedContentLength="262144000" />
        </requestFiltering>
      </security>

    </system.webServer>
  </location>
</configuration>
