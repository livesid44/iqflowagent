<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config for IIS / Azure App Service hosting.

  When this application is published with `dotnet publish`, the ASP.NET Core SDK
  automatically transforms the <aspNetCore> element below, replacing the
  %LAUNCHER_PATH% / %LAUNCHER_ARGS% tokens with the correct values for the
  target deployment (framework-dependent or self-contained).

  The <requestFiltering> section overrides IIS's built-in request-body size
  limit.  IIS defaults to 30,000,000 bytes (~28.6 MB); without this entry any
  upload larger than that is rejected with HTTP 413 ("The page was not
  displayed because the request entity is too large") before the request even
  reaches the ASP.NET Core / Kestrel layer.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>

      <!-- Route every request through the ASP.NET Core Module v2 -->
      <handlers>
        <add name="aspNetCore" path="*" verb="*"
             modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <!--
        processPath / arguments are replaced by the publish transform.

        hostingModel="outofprocess": the .NET application runs as a separate Kestrel
        process; IIS proxies requests to it via a named-pipe / localhost connection.
        This is the recommended setting for resilience: if the .NET process crashes or
        is recycled, IIS returns a transient 502 and automatically restarts the process
        WITHOUT affecting the IIS worker process (w3wp.exe).  The "503 Application
        Shutting Down" response is exclusive to in-process hosting — switching to
        out-of-process eliminates it entirely.

        stdoutLogEnabled: set to "true" to capture startup errors in logs\stdout*.log.
        The "logs" directory must exist in the deployment root before enabling this.
        IQFlowAgent creates this directory automatically on first startup.

        startupTimeLimit (seconds, default 120): how long ANCM waits for the Kestrel
        process to start listening.  300 seconds (5 minutes) covers a slow SQL Server
        migration on the first deploy.

        shutdownTimeLimit (seconds, default 10): how long ANCM waits for in-flight
        requests to drain after a recycle signal.  30 seconds lets long-running AI
        API calls finish cleanly instead of being aborted mid-flight.
      -->
      <aspNetCore processPath="%LAUNCHER_PATH%" arguments="%LAUNCHER_ARGS%"
                  stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout"
                  hostingModel="outofprocess"
                  startupTimeLimit="300"
                  shutdownTimeLimit="30">
        <environmentVariables>
          <!--
            Uncomment the line below to enable the ASP.NET Core developer-exception page
            and detailed logging on the production IIS server (useful for one-off diagnosis;
            comment it out again afterwards):

            <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Development" />
          -->
        </environmentVariables>
      </aspNetCore>

      <security>
        <requestFiltering>
          <!--
            Raise the IIS request-body size limit to 250 MB to match the value
            configured in AppConstants.MaxUploadBytes (262,144,000 bytes).

            250 MB  =  250 × 1,048,576  =  262,144,000 bytes
          -->
          <requestLimits maxAllowedContentLength="262144000" />
        </requestFiltering>
      </security>

    </system.webServer>
  </location>
</configuration>
