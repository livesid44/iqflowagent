@{
    var intake       = ViewBag.Intake as IQFlowAgent.Web.Models.IntakeRecord;
    var report       = ViewBag.Report as IQFlowAgent.Web.Models.FinalReport;
    string? filePath = ViewBag.ReportPath as string;
    string? fileName = ViewBag.ReportFileName as string;
    string? sizeKb   = ViewBag.ReportSizeKb as string;
}

@await Html.PartialAsync("_AppShell", new ViewDataDictionary(ViewData) { { "ActivePage", "report" } })

<style>
    .gen-page { padding: 60px 32px; max-width: 680px; margin: 0 auto; text-align: center; }
    .gen-icon { font-size: 4rem; margin-bottom: 16px; }
    .gen-title { font-size: 1.6rem; font-weight: 800; color: #1a1a2e; margin-bottom: 8px; }
    .gen-subtitle { font-size: 0.9rem; color: #6b7280; margin-bottom: 32px; }
    .report-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px 32px; text-align: left; margin-bottom: 28px; }
    .report-card-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #f3f4f6; font-size: 0.84rem; }
    .report-card-row:last-child { border-bottom: none; }
    .report-card-lbl { color: #6b7280; }
    .report-card-val { font-weight: 600; color: #1a1a2e; }
    .btn-download { background: linear-gradient(90deg,#10b981,#059669); color: #fff; padding: 14px 32px; border-radius: 10px; border: none; font-weight: 700; font-size: 1rem; text-decoration: none; display: inline-block; margin-bottom: 12px; }
    .btn-intakes  { background: #f3f4f6; color: #374151; padding: 12px 24px; border-radius: 10px; border: 1px solid #e5e7eb; font-weight: 600; font-size: 0.9rem; text-decoration: none; display: inline-block; }
    .btn-regen    { background: #eff6ff; color: #1d4ed8; padding: 12px 24px; border-radius: 10px; border: 1px solid #bfdbfe; font-weight: 600; font-size: 0.9rem; cursor: pointer; display: inline-block; }
    .btn-regen:hover { background: #dbeafe; }
    .closed-badge { display: inline-block; background: #d1fae5; color: #065f46; padding: 4px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; margin-top: 8px; }
</style>

<main class="app-main">
<div class="gen-page">
    <div class="gen-icon">🎉</div>
    <div class="gen-title">Final Report Generated!</div>
    <div class="gen-subtitle">
        The BARTOK Due Diligence report for intake <strong>@intake?.IntakeId</strong> has been successfully generated
        and the intake status has been set to <span class="closed-badge">Closed</span>
    </div>

    <div class="report-card">
        <div class="report-card-row">
            <span class="report-card-lbl">File Name</span>
            <span class="report-card-val">@fileName</span>
        </div>
        <div class="report-card-row">
            <span class="report-card-lbl">Intake</span>
            <span class="report-card-val">@intake?.IntakeId — @intake?.ProcessName</span>
        </div>
        <div class="report-card-row">
            <span class="report-card-lbl">Generated</span>
            <span class="report-card-val">@(report?.GeneratedAt.ToString("dd MMM yyyy HH:mm") ?? DateTime.UtcNow.ToString("dd MMM yyyy HH:mm"))</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(sizeKb))
        {
            <div class="report-card-row">
                <span class="report-card-lbl">File Size</span>
                <span class="report-card-val">@sizeKb KB</span>
            </div>
        }
        <div class="report-card-row">
            <span class="report-card-lbl">Storage</span>
            <span class="report-card-val">@(filePath?.StartsWith("http") == true ? "☁️ Azure Blob Storage" : "📁 Local Storage")</span>
        </div>
    </div>

    @if (intake != null && !string.IsNullOrWhiteSpace(filePath))
    {
        <a href="/Report/Download?intakeId=@intake.Id" class="btn-download">⬇️ Download Report (Word)</a>
    }
    <br/>
    @if (intake != null)
    {
        <form method="post" action="/Report/RegenerateReport" style="display:inline;"
              onsubmit="return confirm('Regenerate the report from current field values? A new Word document will be created.');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="intakeId" value="@intake.Id" />
            <button type="submit" class="btn-regen">🔄 Regenerate Report</button>
        </form>
        <span style="display:inline-block;width:8px;"></span>
    }
    <a href="/Intake/Index" class="btn-intakes">← Back to Intakes</a>
</div>
</main>
</div>@* close app-layout *@
