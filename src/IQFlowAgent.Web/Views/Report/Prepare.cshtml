@using IQFlowAgent.Web.Models
@model List<ReportFieldStatus>

@{
    var intake = ViewBag.Intake as IQFlowAgent.Web.Models.IntakeRecord;
    var existingReport = ViewBag.ExistingReport as IQFlowAgent.Web.Models.FinalReport;
    int openTaskCount = ViewBag.OpenTaskCount ?? 0;
    var intakeId = intake?.Id ?? 0;

    int totalFields     = Model.Count;
    int availableFields = Model.Count(f => f.Status == "Available");
    int naFields        = Model.Count(f => f.IsNA || f.Status == "NA");
    int missingFields   = Model.Count(f => f.Status is "Missing" or "Pending");
    int taskCreated     = Model.Count(f => f.Status == "TaskCreated");
    bool allReady       = totalFields > 0 && missingFields == 0 && taskCreated == 0;
    bool hasFields      = totalFields > 0;

    var sections = Model.GroupBy(f => f.Section).OrderBy(g => g.Key);
}

@await Html.PartialAsync("_AppShell", new ViewDataDictionary(ViewData) { { "ActivePage", "report" } })

<style>
    /* ── Empty-state (no intake selected) ─────────────────────────────── */
    .empty-state-box {
        text-align: center; padding: 64px 32px;
        background: #fff; border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.06);
    }
    .empty-state-box .es-icon { font-size: 3rem; margin-bottom: 16px; }
    .empty-state-box h3 { font-size: 1.1rem; font-weight: 700; color: #1a1a2e; margin-bottom: 8px; }
    .empty-state-box p  { font-size: 0.88rem; color: #6b7280; }
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .page-title { font-size: 1.4rem; font-weight: 700; color: #1a1a2e; }
    .page-subtitle { font-size: 0.85rem; color: #6b7280; margin-top: 2px; }

    .progress-banner { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 16px 24px; margin-bottom: 24px; display: flex; gap: 24px; align-items: center; flex-wrap: wrap; }
    .prog-stat { text-align: center; }
    .prog-stat-num { font-size: 1.6rem; font-weight: 800; }
    .prog-stat-lbl { font-size: 0.72rem; color: #6b7280; text-transform: uppercase; letter-spacing: .04em; }
    .prog-stat[data-filter] { cursor: pointer; }
    .prog-stat[data-filter]:hover { opacity: .7; }
    .prog-stat[data-filter] .prog-stat-num { text-decoration: underline; text-underline-offset: 3px; }
    .section-counts span[data-filter] { cursor: pointer; text-decoration: underline; text-underline-offset: 2px; }
    .section-counts span[data-filter]:hover { opacity: .7; }
    .filter-active-banner { background:#eef2ff; border:1px solid #a5b4fc; border-radius:8px; padding:8px 16px; margin-bottom:12px; font-size:0.82rem; color:#3730a3; display:flex; align-items:center; gap:10px; }
    .filter-active-banner .clear-filter { cursor:pointer; font-weight:700; color:#4f46e5; text-decoration:underline; }
    .num-available { color: #10b981; }
    .num-na        { color: #6b7280; }
    .num-missing   { color: #ef4444; }
    .num-task      { color: #f59e0b; }
    .prog-bar-wrap { flex: 1; min-width: 200px; }
    .prog-bar-bg { background: #f3f4f6; border-radius: 8px; height: 10px; overflow: hidden; }
    .prog-bar-fill { height: 100%; border-radius: 8px; background: linear-gradient(90deg,#10b981,#059669); transition: width .4s; }

    .section-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; margin-bottom: 20px; overflow: hidden; }
    .section-header { background: #f9fafb; border-bottom: 1px solid #e5e7eb; padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; }
    .section-title { font-weight: 700; font-size: 0.9rem; color: #1a1a2e; }
    .section-counts { font-size: 0.76rem; color: #6b7280; }

    .field-row { display: grid; grid-template-columns: 200px 1fr 100px 180px; gap: 12px; align-items: start; padding: 14px 20px; border-bottom: 1px solid #f3f4f6; }
    .field-row:last-child { border-bottom: none; }
    .field-label { font-size: 0.82rem; font-weight: 600; color: #374151; padding-top: 4px; }
    .field-value { font-size: 0.82rem; color: #4b5563; }
    .field-value textarea { width: 100%; min-height: 60px; border: 1px solid #d1d5db; border-radius: 6px; padding: 6px 10px; font-size: 0.81rem; font-family: inherit; resize: vertical; }
    .field-notes  { font-size: 0.74rem; color: #9ca3af; margin-top: 4px; font-style: italic; }

    .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 0.71rem; font-weight: 700; text-transform: uppercase; }
    .badge-available { background: #d1fae5; color: #065f46; }
    .badge-missing   { background: #fee2e2; color: #991b1b; }
    .badge-na        { background: #f3f4f6; color: #6b7280; }
    .badge-pending   { background: #fef3c7; color: #92400e; }
    .badge-task      { background: #ede9fe; color: #5b21b6; }

    .btn-ai-gen { background: linear-gradient(135deg,#7c3aed,#5b21b6); color: #fff; padding: 4px 8px; border-radius: 6px; border: none; cursor: pointer; font-size: 0.72rem; font-weight: 600; margin-top: 4px; white-space: nowrap; }
    .btn-ai-gen:disabled { background: #c4b5fd; cursor: wait; }

    .ai-gen-panel { display:none; margin-top:8px; padding:10px 12px; background:#f5f3ff; border:1px solid #ddd6fe; border-radius:8px; }
    .ai-gen-panel textarea { width:100%; border:1px solid #c4b5fd; border-radius:6px; padding:6px 8px; font-size:0.79rem; font-family:inherit; resize:vertical; min-height:48px; }
    .ai-gen-panel .ai-gen-actions { display:flex; gap:8px; margin-top:6px; align-items:center; }
    .ai-gen-panel .ai-gen-note { font-size:0.71rem; color:#6d28d9; }

    .action-btns { display: flex; flex-direction: column; gap: 6px; }
    .btn-sm { padding: 4px 10px; border-radius: 6px; border: none; cursor: pointer; font-size: 0.75rem; font-weight: 600; }
    .btn-save-val   { background: #2563eb; color: #fff; }
    .btn-mark-na    { background: #6b7280; color: #fff; }
    .btn-undo-na    { background: #d97706; color: #fff; }
    .btn-task       { background: #7c3aed; color: #fff; }

    .toolbar { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; align-items: center; }
    .btn-analyze  { background: #2563eb; color: #fff; padding: 10px 20px; border-radius: 8px; border: none; cursor: pointer; font-weight: 700; font-size: 0.85rem; }
    .btn-generate { background: linear-gradient(90deg,#10b981,#059669); color: #fff; padding: 10px 24px; border-radius: 8px; border: none; cursor: pointer; font-weight: 700; font-size: 0.85rem; }
    .btn-generate:disabled { background: #d1d5db; cursor: not-allowed; }
    .btn-back { background: #f3f4f6; color: #374151; padding: 10px 16px; border-radius: 8px; border: 1px solid #e5e7eb; font-weight: 600; font-size: 0.85rem; text-decoration: none; }

    .alert { padding: 12px 18px; border-radius: 8px; margin-bottom: 18px; font-size: 0.84rem; }
    .alert-success { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
    .alert-error   { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
    .alert-info    { background: #dbeafe; color: #1e40af; border: 1px solid #93c5fd; }
    .alert-warning { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }

    .report-ready-box { background: linear-gradient(135deg,#ecfdf5 0%,#d1fae5 100%); border: 1px solid #6ee7b7; border-radius: 10px; padding: 20px 24px; margin-bottom: 24px; }
    .report-ready-box h3 { margin: 0 0 8px; color: #065f46; font-size: 1rem; }
    .report-ready-box p { margin: 0 0 16px; font-size: 0.84rem; color: #047857; }

    .existing-report-box { background: #f0fdf4; border: 1px solid #86efac; border-radius: 10px; padding: 16px 20px; margin-bottom: 20px; font-size: 0.84rem; color: #166534; }

    @@media (max-width: 900px) {
        .field-row { grid-template-columns: 1fr; }
    }
</style>

<main class="app-main">

    @* ── Intake Picker (always visible) ──────────────────────────────────── *@
    @await Html.PartialAsync("_IntakePicker")

    @if (intake == null)
    {
        <div class="empty-state-box">
            <div class="es-icon">📋</div>
            <h3>Select an Intake to Prepare the BARTOK DD Report</h3>
            <p>Choose an intake from the picker above to view or generate the final report for that process.</p>
        </div>
    }
    else
    {
    <div class="page-header">
        <div>
            <div class="page-title">📋 BARTOK DD Report Preparation</div>
            <div class="page-subtitle">
                Intake: <strong>@intake.IntakeId</strong> — @intake.ProcessName
            </div>
        </div>
        <a href="/Task/Index?selectedId=@intakeId" class="btn-back">← Task Board</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error">❌ @TempData["Error"]</div>
    }

    @if (openTaskCount > 0)
    {
        <div class="alert alert-warning">
            ⚠️ <strong>@openTaskCount open task(s)</strong> remain for this intake.
            It is recommended to close all tasks before generating the final report,
            as task artifacts are used to populate report fields.
            <a href="/Task/Index?selectedId=@intakeId" style="color:#92400e;font-weight:700;">View Tasks →</a>
        </div>
    }

    @if (existingReport != null)
    {
        <div class="existing-report-box">
            ✅ A final report was previously generated on <strong>@existingReport.GeneratedAt.ToString("dd MMM yyyy HH:mm")</strong> —
            <strong>@existingReport.ReportFileName</strong>
            @if (existingReport.FilePath.StartsWith("http"))
            {
                <a href="@existingReport.FilePath" target="_blank" style="color:#166534;font-weight:700;margin-left:8px;">☁️ Download from Blob →</a>
            }
            else
            {
                <a href="/Report/Download?intakeId=@intakeId" style="color:#166534;font-weight:700;margin-left:8px;">⬇️ Download →</a>
            }
        </div>
    }

    @if (!hasFields)
    {
        <div class="alert alert-info">
            ℹ️ No field analysis has been run yet.
            Click <strong>"Run AI Field Analysis"</strong> to let the AI determine which BARTOK template fields can be populated from the available intake data and task artifacts.
        </div>
    }
    else
    {
        <!-- Progress Banner -->
        <div class="progress-banner">
            <div class="prog-stat"><div class="prog-stat-num">@totalFields</div><div class="prog-stat-lbl">Total Fields</div></div>
            <div class="prog-stat" data-filter="available" onclick="applyFilter('available')" title="Click to show only Available fields"><div class="prog-stat-num num-available" data-filter="available">@availableFields</div><div class="prog-stat-lbl">Available</div></div>
            <div class="prog-stat" data-filter="na" onclick="applyFilter('na')" title="Click to show only N/A fields"><div class="prog-stat-num num-na" data-filter="na">@naFields</div><div class="prog-stat-lbl">Marked N/A</div></div>
            <div class="prog-stat" data-filter="missing" onclick="applyFilter('missing')" title="Click to show only Missing fields"><div class="prog-stat-num num-missing" data-filter="missing">@missingFields</div><div class="prog-stat-lbl">Missing</div></div>
            <div class="prog-stat" data-filter="task" onclick="applyFilter('task')" title="Click to show only Task Created fields"><div class="prog-stat-num num-task" data-filter="task">@taskCreated</div><div class="prog-stat-lbl">Tasks Created</div></div>
            <div class="prog-bar-wrap">
                @{ var pct = totalFields > 0 ? ((availableFields + naFields) * 100 / totalFields) : 0; }
                <div style="font-size:0.78rem;color:#6b7280;margin-bottom:4px;">@pct% ready</div>
                <div class="prog-bar-bg"><div class="prog-bar-fill" style="width:@pct%"></div></div>
            </div>
        </div>

        @if (allReady)
        {
            <div class="report-ready-box">
                @if (existingReport != null)
                {
                    <h3>✅ All fields are ready! Click below to generate an updated report.</h3>
                    <p>All @totalFields template fields have been resolved (@availableFields available, @naFields marked N/A). Running the analysis again will produce a refreshed Word document automatically.</p>
                }
                else
                {
                    <h3>🎉 All fields are ready! Click below to generate the final report.</h3>
                    <p>All @totalFields template fields have been resolved (@availableFields available, @naFields marked N/A). The BARTOK DD document will be generated and the intake will be marked as <strong>Closed</strong>.</p>
                }
            </div>
        }
    }

    <!-- Toolbar: single unified action — always "Run AI Field Analysis".
         If all fields resolve, the server auto-generates the report and redirects
         to the download page. If open points remain, this page is shown with the
         outstanding fields highlighted. -->
    <div class="toolbar">
        <form method="post" action="/Report/AnalyzeFields" onsubmit="return startAnalysis()">
            @Html.AntiForgeryToken()
            <input type="hidden" name="intakeId" value="@intakeId" />
            <button type="submit" class="btn-analyze">
                @(hasFields ? "🔄 Re-run AI Field Analysis" : "🤖 Run AI Field Analysis")
            </button>
        </form>
    </div>

    <!-- Analysis loading overlay — shown while AI analysis (and optional auto-generation) runs -->
    <div id="analysisOverlay"
         style="display:none;position:fixed;inset:0;background:rgba(15,23,42,0.6);z-index:9999;
                align-items:center;justify-content:center;">
        <div style="background:#fff;border-radius:16px;padding:40px 48px;text-align:center;
                    max-width:460px;box-shadow:0 20px 60px rgba(0,0,0,.3);">
            <div style="font-size:2.5rem;margin-bottom:16px;">🔬</div>
            <div style="font-weight:700;font-size:1.15rem;color:#1e293b;margin-bottom:10px;">
                Running AI Field Analysis
            </div>
            <div style="color:#64748b;font-size:0.88rem;line-height:1.6;margin-bottom:20px;">
                Each BARTOK section is analyzed with a focused AI call. If all fields resolve,
                the final Word document is generated automatically — no extra click needed.
                This takes <strong>1–3 minutes</strong>; please do not close this page.
            </div>
            <div style="display:flex;align-items:center;justify-content:center;gap:10px;
                        color:#2563eb;font-size:0.9rem;font-weight:600;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5"
                     style="animation:spin 1s linear infinite;">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83
                             M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
                </svg>
                Analyzing…
            </div>
        </div>
    </div>

    <!-- Generate loading overlay — no longer used from the toolbar; kept for the
         legacy /Report/Generate endpoint if accessed directly. -->
    <div id="generateOverlay"
         style="display:none;position:fixed;inset:0;background:rgba(15,23,42,0.6);z-index:9999;
                align-items:center;justify-content:center;">
        <div style="background:#fff;border-radius:16px;padding:40px 48px;text-align:center;
                    max-width:480px;box-shadow:0 20px 60px rgba(0,0,0,.3);">
            <div style="font-size:2.5rem;margin-bottom:16px;">📄</div>
            <div style="font-weight:700;font-size:1.15rem;color:#1e293b;margin-bottom:10px;">
                Generating Final Report
            </div>
            <div style="color:#64748b;font-size:0.88rem;line-height:1.6;margin-bottom:20px;">
                Running the complete AI pipeline for all BARTOK sections — RACI, SOP, Volume,
                OSS and more — then producing the final Word document. This takes
                <strong>2–3 minutes</strong> for typical intakes; large documents or high
                system load may take longer. Please do not close this page.
            </div>
            <div style="display:flex;align-items:center;justify-content:center;gap:10px;
                        color:#059669;font-size:0.9rem;font-weight:600;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5"
                     style="animation:spin 1s linear infinite;">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83
                             M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
                </svg>
                Processing…
            </div>
        </div>
    </div>
    <style>
        @@keyframes spin { to { transform: rotate(360deg); } }
    </style>
    <script>
        function startAnalysis() {
            var overlay = document.getElementById('analysisOverlay');
            if (overlay) overlay.style.display = 'flex';
            document.querySelectorAll('.btn-analyze').forEach(function(b) { b.disabled = true; });
            return true;
        }
    </script>

    @if (hasFields)
    {
        <div id="filterBanner" class="filter-active-banner" style="display:none;">
            <span>🔍 Showing only <strong id="filterLabel"></strong> fields.</span>
            <span class="clear-filter" onclick="clearFilter()">✕ Show all</span>
        </div>

        foreach (var sectionGroup in sections)
        {
            var sAvail   = sectionGroup.Count(f => f.Status == "Available");
            var sMissing = sectionGroup.Count(f => f.Status is "Missing" or "Pending" or "TaskCreated");
            var sNA      = sectionGroup.Count(f => f.IsNA);

            <div class="section-card">
                <div class="section-header">
                    <div class="section-title">@sectionGroup.Key</div>
                    <div class="section-counts">
                        <span style="color:#10b981" data-filter="available" onclick="applyFilter('available')" title="Click to show only Available fields">✓ @sAvail ready</span>
                        @if (sNA > 0) { <span style="margin-left:8px;color:#6b7280" data-filter="na" onclick="applyFilter('na')" title="Click to show only N/A fields">N/A: @sNA</span> }
                        @if (sMissing > 0) { <span style="margin-left:8px;color:#ef4444" data-filter="missing" onclick="applyFilter('missing')" title="Click to show only Missing fields">⚠ @sMissing missing</span> }
                    </div>
                </div>

                @foreach (var field in sectionGroup)
                {
                    var fieldFilterStatus = field.IsNA ? "na" : field.Status switch {
                        "Available"   => "available",
                        "Missing"     => "missing",
                        "Pending"     => "missing",
                        "TaskCreated" => "task",
                        "NA"          => "na",
                        _             => "missing"
                    };
                    <div class="field-row" id="field-@field.Id" data-status="@fieldFilterStatus">
                        <!-- Label + status -->
                        <div>
                            <div class="field-label">@field.FieldLabel</div>
                            <div style="margin-top:6px;" id="badge-wrap-@field.Id">
                                @{
                                    var badgeClass = field.IsNA ? "badge-na" : field.Status switch {
                                        "Available"   => "badge-available",
                                        "Missing"     => "badge-missing",
                                        "Pending"     => "badge-pending",
                                        "TaskCreated" => "badge-task",
                                        "NA"          => "badge-na",
                                        _             => "badge-pending"
                                    };
                                    var badgeText = field.IsNA ? "N/A" : field.Status;
                                }
                                <span class="badge @badgeClass" id="badge-@field.Id">@badgeText</span>
                            </div>
                            <div style="font-size:0.73rem;color:#7c3aed;margin-top:4px;@(string.IsNullOrWhiteSpace(field.LinkedTaskId) ? "display:none" : "")" id="task-link-@field.Id">
                                Task: <span id="task-id-@field.Id">@field.LinkedTaskId</span>
                            </div>
                        </div>

                        <!-- Value editor -->
                        <div class="field-value">
                            <form method="post" action="/Report/SetValue" id="save-form-@field.Id"
                                  onsubmit="return saveValueAjax(event, @field.Id)">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="fieldStatusId" value="@field.Id" />
                                <textarea name="fillValue" id="textarea-@field.Id" rows="2" placeholder="@field.TemplatePlaceholder">@field.FillValue</textarea>
                                <div style="margin-top:6px;display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                                    <button type="submit" class="btn-sm btn-save-val" id="save-btn-@field.Id">💾 Save Value</button>
                                    <button type="button" class="btn-ai-gen" id="ai-btn-@field.Id"
                                            onclick="toggleAiPanel(@field.Id)">✨ Generate with AI</button>
                                    <span id="save-status-@field.Id" style="font-size:0.72rem;"></span>
                                </div>
                            </form>
                            <!-- AI generation panel -->
                            <div class="ai-gen-panel" id="ai-panel-@field.Id">
                                <div class="ai-gen-note" style="margin-bottom:6px;">
                                    ✨ AI will generate content for <strong>@field.FieldLabel</strong> based on the intake document. Add any extra context below (optional).
                                </div>
                                <textarea id="ai-ctx-@field.Id" rows="2" placeholder="Optional: add extra context or instructions for the AI…"></textarea>
                                <div class="ai-gen-actions">
                                    <button type="button" class="btn-sm btn-ai-gen" id="ai-run-@field.Id"
                                            onclick="runAiGenerate(@field.Id, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(field.FieldLabel))')">🤖 Generate</button>
                                    <button type="button" class="btn-sm" style="background:#e5e7eb;color:#374151;"
                                            onclick="toggleAiPanel(@field.Id)">Cancel</button>
                                    <span id="ai-status-@field.Id" style="font-size:0.72rem;color:#6d28d9;"></span>
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(field.Notes))
                            {
                                <div class="field-notes">ℹ️ @field.Notes</div>
                            }
                        </div>

                        <!-- Status badge column -->
                        <div style="padding-top:4px;">
                            @if (field.AnalyzedAt.HasValue)
                            {
                                <div style="font-size:0.7rem;color:#9ca3af;">Analyzed<br/>@field.AnalyzedAt.Value.ToString("dd MMM HH:mm")</div>
                            }
                        </div>

                        <!-- Action buttons -->
                        <div class="action-btns" id="actions-@field.Id">
                            @{
                                var showMarkNA = !field.IsNA;
                                var showCreateTask = (field.Status is "Missing" or "Pending" or "TaskCreated") && !field.IsNA;
                            }
                            <form method="post" action="/Report/MarkNA" id="na-form-@field.Id"
                                  onsubmit="return markNaAjax(event, @field.Id, @(field.IsNA ? "false" : "true"))">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="fieldStatusId" value="@field.Id" />
                                <input type="hidden" name="isNA" value="@(field.IsNA ? "false" : "true")" id="na-val-@field.Id" />
                                <button type="submit" class="btn-sm @(field.IsNA ? "btn-undo-na" : "btn-mark-na")" id="na-btn-@field.Id">
                                    @(field.IsNA ? "Undo N/A" : "Mark N/A")
                                </button>
                            </form>

                            <form method="post" action="/Report/CreateTaskForField" id="task-form-@field.Id"
                                  style="@(showCreateTask ? "" : "display:none")"
                                  onsubmit="return createTaskAjax(event, @field.Id)">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="fieldStatusId" value="@field.Id" />
                                <button type="submit" class="btn-sm btn-task" id="task-btn-@field.Id">+ Create Task</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    }
    } @* end else (intake selected) *@
</main>
</div>@* close app-layout *@

@section Scripts {
<script>
function toggleAiPanel(fieldId) {
    const panel = document.getElementById('ai-panel-' + fieldId);
    panel.style.display = panel.style.display === 'block' ? 'none' : 'block';
}

async function runAiGenerate(fieldId, fieldLabel) {
    const runBtn   = document.getElementById('ai-run-'    + fieldId);
    const statusEl = document.getElementById('ai-status-' + fieldId);
    const ctxEl    = document.getElementById('ai-ctx-'    + fieldId);
    const taEl     = document.getElementById('textarea-'  + fieldId);
    const form     = document.getElementById('save-form-' + fieldId);
    const token    = form.querySelector('input[name="__RequestVerificationToken"]').value;

    runBtn.disabled = true;
    runBtn.textContent = '⏳ Generating…';
    statusEl.textContent = '';

    const formData = new FormData();
    formData.append('fieldStatusId', fieldId);
    formData.append('userContext',   ctxEl.value || '');
    formData.append('__RequestVerificationToken', token);

    try {
        const resp = await fetch('/Report/AiGenerateField', { method: 'POST', body: formData });
        const data = await resp.json();
        if (data.success) {
            taEl.value = data.value;
            statusEl.textContent = '✓ Generated — review and click Save Value.';
            statusEl.style.color = '#059669';
            document.getElementById('ai-panel-' + fieldId).style.display = 'none';
        } else {
            statusEl.textContent = '✗ ' + (data.message || 'Generation failed.');
            statusEl.style.color = '#dc2626';
        }
    } catch (ex) {
        statusEl.textContent = '✗ Network error: ' + ex.message;
        statusEl.style.color = '#dc2626';
    }
    runBtn.disabled = false;
    runBtn.textContent = '🤖 Generate';
}

/* ── AJAX helpers ──────────────────────────────────────────────── */
var badgeMap = {
    'Available':   { cls: 'badge-available', text: 'Available',   filter: 'available' },
    'Missing':     { cls: 'badge-missing',   text: 'Missing',     filter: 'missing' },
    'Pending':     { cls: 'badge-pending',   text: 'Pending',     filter: 'missing' },
    'TaskCreated': { cls: 'badge-task',      text: 'TaskCreated', filter: 'task' },
    'NA':          { cls: 'badge-na',        text: 'N/A',         filter: 'na' }
};

function updateFieldBadge(fieldId, status, isNA) {
    var row   = document.getElementById('field-' + fieldId);
    var badge = document.getElementById('badge-' + fieldId);
    if (!row || !badge) return;

    var info = isNA ? badgeMap['NA'] : (badgeMap[status] || badgeMap['Missing']);
    badge.className = 'badge ' + info.cls;
    badge.textContent = info.text;
    row.setAttribute('data-status', info.filter);

    // Update the NA button
    var naBtn = document.getElementById('na-btn-' + fieldId);
    var naVal = document.getElementById('na-val-' + fieldId);
    if (naBtn && naVal) {
        if (isNA) {
            naBtn.textContent = 'Undo N/A';
            naBtn.className = 'btn-sm btn-undo-na';
            naVal.value = 'false';
        } else {
            naBtn.textContent = 'Mark N/A';
            naBtn.className = 'btn-sm btn-mark-na';
            naVal.value = 'true';
        }
    }

    // Show/hide Create Task button
    var taskForm = document.getElementById('task-form-' + fieldId);
    if (taskForm) {
        var showTask = !isNA && (status === 'Missing' || status === 'Pending' || status === 'TaskCreated');
        taskForm.style.display = showTask ? '' : 'none';
    }

    // Reapply active filter if present
    if (currentFilter) { applyFilter(currentFilter); }
}

function updateProgressCounts() {
    var rows = document.querySelectorAll('.field-row');
    var total = rows.length, avail = 0, na = 0, missing = 0, task = 0;
    rows.forEach(function(r) {
        switch (r.getAttribute('data-status')) {
            case 'available': avail++; break;
            case 'na': na++; break;
            case 'task': task++; break;
            default: missing++; break;
        }
    });
    // Update the banner numbers
    document.querySelectorAll('.prog-stat-num[data-filter="available"]').forEach(function(el) { el.textContent = avail; });
    document.querySelectorAll('.prog-stat-num[data-filter="na"]').forEach(function(el) { el.textContent = na; });
    document.querySelectorAll('.prog-stat-num[data-filter="missing"]').forEach(function(el) { el.textContent = missing; });
    document.querySelectorAll('.prog-stat-num[data-filter="task"]').forEach(function(el) { el.textContent = task; });
    // Update progress bar
    var pct = total > 0 ? Math.round((avail + na) * 100 / total) : 0;
    var fillBar = document.querySelector('.prog-bar-fill');
    if (fillBar) fillBar.style.width = pct + '%';
    var pctLabel = document.querySelector('.prog-bar-wrap > div');
    if (pctLabel) pctLabel.textContent = pct + '% ready';
}

function showInlineStatus(fieldId, elementId, message, isSuccess) {
    var el = document.getElementById(elementId);
    if (el) {
        el.textContent = message;
        el.style.color = isSuccess ? '#059669' : '#dc2626';
        if (isSuccess) { setTimeout(function() { el.textContent = ''; }, 3000); }
    }
}

/* ── Save Value via AJAX ───────────────────────────────────────── */
async function saveValueAjax(event, fieldId) {
    event.preventDefault();
    var form = document.getElementById('save-form-' + fieldId);
    var btn  = document.getElementById('save-btn-' + fieldId);
    var statusEl = 'save-status-' + fieldId;
    btn.disabled = true;
    btn.textContent = '⏳ Saving…';

    try {
        var formData = new FormData(form);
        var resp = await fetch('/Report/SetValue', {
            method: 'POST',
            body: formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        var data = await resp.json();
        if (data.success) {
            updateFieldBadge(fieldId, data.status, data.isNA);
            updateProgressCounts();
            showInlineStatus(fieldId, statusEl, '✓ Saved', true);
        } else {
            showInlineStatus(fieldId, statusEl, '✗ ' + (data.message || 'Save failed.'), false);
        }
    } catch (ex) {
        showInlineStatus(fieldId, statusEl, '✗ Network error: ' + ex.message, false);
    }
    btn.disabled = false;
    btn.textContent = '💾 Save Value';
    return false;
}

/* ── Mark N/A via AJAX ─────────────────────────────────────────── */
async function markNaAjax(event, fieldId, newIsNA) {
    event.preventDefault();
    var btn = document.getElementById('na-btn-' + fieldId);
    btn.disabled = true;
    btn.textContent = '⏳ …';

    try {
        var form = document.getElementById('na-form-' + fieldId);
        var formData = new FormData(form);
        var resp = await fetch('/Report/MarkNA', {
            method: 'POST',
            body: formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        var data = await resp.json();
        if (data.success) {
            updateFieldBadge(fieldId, data.status, data.isNA);
            updateProgressCounts();
        } else {
            alert('Failed: ' + (data.message || 'Unknown error.'));
        }
    } catch (ex) {
        alert('Network error: ' + ex.message);
    }
    btn.disabled = false;
    // Button text/class is updated by updateFieldBadge
}

/* ── Create Task via AJAX ──────────────────────────────────────── */
async function createTaskAjax(event, fieldId) {
    event.preventDefault();
    var btn = document.getElementById('task-btn-' + fieldId);
    btn.disabled = true;
    btn.textContent = '⏳ Creating…';

    try {
        var form = document.getElementById('task-form-' + fieldId);
        var formData = new FormData(form);
        var resp = await fetch('/Report/CreateTaskForField', {
            method: 'POST',
            body: formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        var data = await resp.json();
        if (data.success) {
            updateFieldBadge(fieldId, 'TaskCreated', false);
            // Show linked task ID
            var taskLink = document.getElementById('task-link-' + fieldId);
            var taskIdEl = document.getElementById('task-id-' + fieldId);
            if (taskLink && taskIdEl) {
                taskIdEl.textContent = data.taskId;
                taskLink.style.display = '';
            }
            updateProgressCounts();
            showInlineStatus(fieldId, 'save-status-' + fieldId, '✓ Task ' + data.taskId + ' created', true);
        } else {
            alert('Failed to create task: ' + (data.message || 'Unknown error.'));
        }
    } catch (ex) {
        alert('Network error creating task: ' + ex.message);
    }
    btn.disabled = false;
    btn.textContent = '+ Create Task';
    return false;
}

/* ── Status filter ─────────────────────────────────────────────── */
var currentFilter = null;
var filterLabels = { available: 'Available', missing: 'Missing', na: 'N/A', task: 'Task Created' };

function applyFilter(status) {
    if (currentFilter === status) { clearFilter(); return; }
    currentFilter = status;

    var banner = document.getElementById('filterBanner');
    var label  = document.getElementById('filterLabel');
    if (banner && label) {
        label.textContent = filterLabels[status] || status;
        banner.style.display = 'flex';
    }

    document.querySelectorAll('.field-row').forEach(function(row) {
        row.style.display = row.getAttribute('data-status') === status ? '' : 'none';
    });

    // Hide section cards that have no visible field rows
    document.querySelectorAll('.section-card').forEach(function(card) {
        var visibleRows = card.querySelectorAll('.field-row:not([style*="display: none"])');
        card.style.display = visibleRows.length > 0 ? '' : 'none';
    });
}

function clearFilter() {
    currentFilter = null;
    var banner = document.getElementById('filterBanner');
    if (banner) banner.style.display = 'none';

    document.querySelectorAll('.field-row').forEach(function(row) {
        row.style.display = '';
    });
    document.querySelectorAll('.section-card').forEach(function(card) {
        card.style.display = '';
    });
}

/* ── Scroll to anchor on page load ─────────────────────────────── */
document.addEventListener('DOMContentLoaded', function() {
    if (window.location.hash) {
        var el = document.querySelector(window.location.hash);
        if (el) { setTimeout(function() { el.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 100); }
    }
});
</script>
}
