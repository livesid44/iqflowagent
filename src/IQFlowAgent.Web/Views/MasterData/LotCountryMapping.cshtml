@model List<IQFlowAgent.Web.Models.LotCountryMapping>
@{
    Layout = "_Layout";
    ViewData["Title"] = "LOT Country / City Mapping";
    ViewData["ActivePage"] = "masterdatalotcountry";
    var lotOptions = ViewBag.LotOptions as string[] ?? Array.Empty<string>();
    var useFilter  = (bool)(ViewBag.UseCountryFilterByLot ?? false);
    var lotsJson   = System.Text.Json.JsonSerializer.Serialize(lotOptions);
}

@await Html.PartialAsync("_AppShell", new ViewDataDictionary(ViewData))

<main class="app-main">
<style>
.master-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:10px; }
.master-card { background:#fff; border-radius:12px; padding:24px; box-shadow:0 2px 10px rgba(0,0,0,.07); }
.btn-add { background:#e31837; color:#fff; border:none; border-radius:8px; padding:9px 20px; font-size:0.88rem; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; }
.btn-add:hover { background:#c01530; }
.master-table { width:100%; border-collapse:collapse; font-size:0.88rem; }
.master-table th { background:#f8faff; color:#1a2a5e; font-weight:700; padding:10px 14px; border-bottom:2px solid #e5e9f2; text-align:left; }
.master-table td { padding:10px 14px; border-bottom:1px solid #f0f2f8; vertical-align:middle; }
.master-table tr:last-child td { border-bottom:none; }
.badge-active { background:#d1fae5; color:#065f46; border-radius:12px; padding:2px 10px; font-size:0.78rem; font-weight:600; }
.badge-inactive { background:#fee2e2; color:#991b1b; border-radius:12px; padding:2px 10px; font-size:0.78rem; font-weight:600; }
.btn-sm { border:none; border-radius:6px; padding:4px 12px; font-size:0.78rem; cursor:pointer; font-weight:600; }
.btn-edit-sm { background:#e0e7ff; color:#3730a3; }
.btn-edit-sm:hover { background:#c7d2fe; }
.btn-toggle-sm { background:#fef9c3; color:#854d0e; }
.btn-toggle-sm:hover { background:#fde68a; }
.btn-del-sm { background:#fee2e2; color:#991b1b; }
.btn-del-sm:hover { background:#fecaca; }
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:1000; align-items:center; justify-content:center; }
.modal-overlay.open { display:flex; }
.modal-box { background:#fff; border-radius:14px; padding:28px 32px; width:520px; max-width:95vw; box-shadow:0 8px 32px rgba(0,0,0,.18); }
.modal-box h4 { font-size:1rem; font-weight:700; color:#1a2a5e; margin:0 0 18px; }
.modal-field { margin-bottom:14px; }
.modal-field label { display:block; font-size:0.8rem; font-weight:600; color:#444; margin-bottom:4px; }
.modal-field input, .modal-field textarea, .modal-field select { width:100%; border:1px solid #ddd; border-radius:6px; padding:8px 10px; font-size:0.88rem; box-sizing:border-box; }
.modal-actions { display:flex; gap:10px; margin-top:18px; }
.btn-save { background:#e31837; color:#fff; border:none; border-radius:6px; padding:8px 22px; font-weight:600; cursor:pointer; font-size:0.88rem; }
.btn-save:hover { background:#c01530; }
.btn-cancel-modal { background:#f1f5f9; border:1px solid #ddd; border-radius:6px; padding:8px 18px; cursor:pointer; font-size:0.88rem; }
.empty-state { text-align:center; padding:40px 20px; color:#aaa; }
.filter-bar { display:flex; gap:12px; margin-bottom:18px; flex-wrap:wrap; align-items:center; }
.filter-bar select { border:1px solid #ddd; border-radius:6px; padding:7px 12px; font-size:0.85rem; min-width:220px; }
.breadcrumbs { font-size:0.82rem; color:#888; margin-bottom:14px; }
.breadcrumbs a { color:#1a2a5e; text-decoration:none; }
.breadcrumbs a:hover { text-decoration:underline; }
.toggle-bar { background:#f8faff; border:1px solid #c8d5f0; border-radius:10px; padding:14px 18px; margin-bottom:20px;
              display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
.toggle-bar-label { font-size:0.88rem; font-weight:600; color:#1a2a5e; }
.toggle-bar-desc  { font-size:0.78rem; color:#666; margin-top:2px; }
/* Toggle switch */
.toggle-switch { position:relative; display:inline-block; width:46px; height:26px; flex-shrink:0; }
.toggle-switch input { opacity:0; width:0; height:0; }
.toggle-slider { position:absolute; cursor:pointer; inset:0; background:#ccc; border-radius:26px; transition:.3s; }
.toggle-slider:before { content:""; position:absolute; height:20px; width:20px; left:3px; bottom:3px; background:#fff; border-radius:50%; transition:.3s; }
.toggle-switch input:checked + .toggle-slider { background:#1a2a5e; }
.toggle-switch input:checked + .toggle-slider:before { transform:translateX(20px); }
.lot-badge { background:#dbeafe; color:#1e40af; border-radius:12px; padding:2px 10px; font-size:0.78rem; font-weight:600; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.city-tag { display:inline-block; background:#f0fdf4; color:#166534; border:1px solid #bbf7d0; border-radius:10px; padding:1px 8px; font-size:0.75rem; margin:2px; }
</style>

<div class="breadcrumbs">
    <a asp-controller="MasterData" asp-action="Department">Master Data</a> /
    <strong>LOT Country / City Mapping</strong>
</div>

<div class="master-header">
    <div>
        <div class="page-title">LOT → Country / City Mapping</div>
        <div class="page-sub">Configure which countries and cities are available for each LOT when LOT-based filtering is enabled.</div>
    </div>
    <button class="btn-add" onclick="openAddModal()">+ Add Mapping</button>
</div>

<!-- LOT filter toggle -->
<div class="toggle-bar">
    <div>
        <div class="toggle-bar-label">Country/City filtering by LOT</div>
        <div class="toggle-bar-desc">
            @if (useFilter)
            {
                <span style="color:#065f46">✓ Enabled — intake forms will show only the countries/cities mapped to the selected LOT(s).</span>
            }
            else
            {
                <span>Disabled — intake forms show the full global master country/city list.</span>
            }
        </div>
    </div>
    <form asp-action="SaveLotFilterSetting" method="post" style="margin:0;display:flex;align-items:center;gap:10px;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="useCountryFilterByLot" value="@(useFilter ? "false" : "true")" />
        <label class="toggle-switch">
            <input type="checkbox" @(useFilter ? "checked" : "") onchange="this.form.submit()" />
            <span class="toggle-slider"></span>
        </label>
        <span style="font-size:0.82rem;color:#555;">@(useFilter ? "On" : "Off")</span>
    </form>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:#d1fae5;border:1px solid #6ee7b7;border-radius:8px;padding:10px 16px;margin-bottom:16px;color:#065f46;font-size:0.88rem;">
        ✓ @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:10px 16px;margin-bottom:16px;color:#991b1b;font-size:0.88rem;">
        ⚠ @TempData["Error"]
    </div>
}

<!-- Filter by LOT -->
<div class="filter-bar">
    <select id="lotFilter" onchange="filterByLot(this.value)">
        <option value="">All LOTs</option>
        @foreach (var lot in lotOptions)
        {
            <option value="@lot">@lot</option>
        }
    </select>
    <span style="font-size:0.83rem;color:#888;align-self:center;">@Model.Count mapping(s) total</span>
</div>

<div class="master-card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div style="font-size:2rem;margin-bottom:8px;">🗺</div>
            <div>No LOT → Country mappings configured yet.</div>
            <div style="margin-top:6px;font-size:0.82rem;color:#bbb;">Add a mapping to restrict which countries/cities appear when a LOT is selected.</div>
        </div>
    }
    else
    {
        <table class="master-table" id="mappingTable">
            <thead>
                <tr>
                    <th>LOT</th>
                    <th>Country</th>
                    <th>Cities (empty = all cities)</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr data-lot="@m.LotName">
                        <td><span class="lot-badge" title="@m.LotName">@m.LotName</span></td>
                        <td><strong>@m.Country</strong></td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(m.Cities))
                            {
                                <span style="color:#aaa;font-size:0.8rem;">All cities</span>
                            }
                            else
                            {
                                @foreach (var city in m.Cities.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                {
                                    <span class="city-tag">@city</span>
                                }
                            }
                        </td>
                        <td>
                            <span class="@(m.IsActive ? "badge-active" : "badge-inactive")">
                                @(m.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td style="display:flex;gap:6px;flex-wrap:wrap;">
                            <button class="btn-sm btn-edit-sm"
                                    data-id="@m.Id"
                                    data-lot="@m.LotName"
                                    data-country="@m.Country"
                                    data-cities="@m.Cities"
                                    data-active="@(m.IsActive ? "true" : "false")"
                                    onclick="openEditModal(this)">Edit</button>
                            <form asp-action="ToggleLotCountryMapping" asp-route-id="@m.Id" method="post" style="margin:0;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-sm btn-toggle-sm">@(m.IsActive ? "Deactivate" : "Activate")</button>
                            </form>
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <form asp-action="DeleteLotCountryMapping" asp-route-id="@m.Id" method="post" style="margin:0;"
                                      data-country="@m.Country"
                                      onsubmit="return confirm('Delete mapping for \'' + this.dataset.country + '\'?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-sm btn-del-sm">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
</main>
</div>
</div>

<!-- Add Mapping Modal -->
<div class="modal-overlay" id="addModal">
    <div class="modal-box">
        <h4>Add LOT → Country Mapping</h4>
        <form asp-action="CreateLotCountryMapping" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-field">
                <label>LOT <span style="color:#e31837">*</span></label>
                <select name="lotName" required>
                    <option value="">— Select LOT —</option>
                    @foreach (var lot in lotOptions)
                    {
                        <option value="@lot">@lot</option>
                    }
                </select>
            </div>
            <div class="modal-field">
                <label>Country <span style="color:#e31837">*</span></label>
                <input type="text" id="addCountry" name="country" required maxlength="100"
                       placeholder="e.g. India" autocomplete="off" list="countryList" />
                <datalist id="countryList"></datalist>
            </div>
            <div class="modal-field">
                <label>Cities <span style="font-weight:400;color:#888;">(optional — comma-separated; leave empty for all cities)</span></label>
                <input type="text" name="cities" maxlength="2000"
                       placeholder="e.g. Mumbai, Delhi, Bangalore" />
            </div>
            <div class="modal-actions">
                <button type="submit" class="btn-save">Add Mapping</button>
                <button type="button" class="btn-cancel-modal" onclick="closeModal('addModal')">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Mapping Modal -->
<div class="modal-overlay" id="editModal">
    <div class="modal-box">
        <h4>Edit Mapping</h4>
        <form id="editForm" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-field">
                <label>LOT <span style="color:#e31837">*</span></label>
                <select id="editLot" name="lotName" required>
                    <option value="">— Select LOT —</option>
                    @foreach (var lot in lotOptions)
                    {
                        <option value="@lot">@lot</option>
                    }
                </select>
            </div>
            <div class="modal-field">
                <label>Country <span style="color:#e31837">*</span></label>
                <input type="text" id="editCountry" name="country" required maxlength="100"
                       autocomplete="off" list="countryListEdit" />
                <datalist id="countryListEdit"></datalist>
            </div>
            <div class="modal-field">
                <label>Cities <span style="font-weight:400;color:#888;">(optional — comma-separated)</span></label>
                <input type="text" id="editCities" name="cities" maxlength="2000" />
            </div>
            <div class="modal-field">
                <label>
                    <input type="checkbox" id="editActive" name="isActive" value="true" style="width:auto;margin-right:6px;" />
                    Active
                </label>
            </div>
            <div class="modal-actions">
                <button type="submit" class="btn-save">Save Changes</button>
                <button type="button" class="btn-cancel-modal" onclick="closeModal('editModal')">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script src="~/js/country-city-data.js"></script>
<script>
const LOT_OPTIONS = @Html.Raw(lotsJson);

// Populate datalists from country-city-data.js global COUNTRY_CITY_MAP
function populateCountryDatalist() {
    const countries = typeof COUNTRY_CITY_MAP !== 'undefined' ? Object.keys(COUNTRY_CITY_MAP) : [];
    ['countryList', 'countryListEdit'].forEach(id => {
        const dl = document.getElementById(id);
        if (!dl) return;
        dl.innerHTML = '';
        countries.forEach(c => {
            const opt = document.createElement('option'); opt.value = c; dl.appendChild(opt);
        });
    });
}
populateCountryDatalist();

function openAddModal() { document.getElementById('addModal').classList.add('open'); }

function openEditModal(btn) {
    const id       = btn.dataset.id;
    const lot      = btn.dataset.lot;
    const country  = btn.dataset.country;
    const cities   = btn.dataset.cities;
    const isActive = btn.dataset.active === 'true';

    document.getElementById('editForm').action = '/MasterData/EditLotCountryMapping/' + id;
    document.getElementById('editCountry').value  = country;
    document.getElementById('editCities').value   = cities;
    document.getElementById('editActive').checked = isActive;

    const lotSel = document.getElementById('editLot');
    for (let i = 0; i < lotSel.options.length; i++)
        lotSel.options[i].selected = lotSel.options[i].value === lot;

    document.getElementById('editModal').classList.add('open');
}

function closeModal(id) { document.getElementById(id).classList.remove('open'); }

['addModal','editModal'].forEach(id => {
    document.getElementById(id).addEventListener('click', e => {
        if (e.target.id === id) closeModal(id);
    });
});

function filterByLot(lot) {
    document.querySelectorAll('#mappingTable tbody tr').forEach(row => {
        row.style.display = (!lot || row.dataset.lot === lot) ? '' : 'none';
    });
}
</script>
}
