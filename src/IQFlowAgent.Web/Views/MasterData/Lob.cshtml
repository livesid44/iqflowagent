@model List<IQFlowAgent.Web.Models.MasterLob>
@{
    Layout = "_Layout";
    ViewData["Title"] = "LOB Master Data";
    ViewData["ActivePage"] = "masterdata";
    var departments = ViewBag.Departments as List<string> ?? new List<string>();
    var deptJson = System.Text.Json.JsonSerializer.Serialize(departments);
}

@await Html.PartialAsync("_AppShell", new ViewDataDictionary(ViewData))

<main class="app-main">
<style>
.master-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
.master-card { background:#fff; border-radius:12px; padding:24px; box-shadow:0 2px 10px rgba(0,0,0,.07); }
.btn-add { background:#e31837; color:#fff; border:none; border-radius:8px; padding:9px 20px; font-size:0.88rem; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; }
.btn-add:hover { background:#c01530; }
.master-table { width:100%; border-collapse:collapse; font-size:0.88rem; }
.master-table th { background:#f8faff; color:#1a2a5e; font-weight:700; padding:10px 14px; border-bottom:2px solid #e5e9f2; text-align:left; }
.master-table td { padding:10px 14px; border-bottom:1px solid #f0f2f8; vertical-align:middle; }
.master-table tr:last-child td { border-bottom:none; }
.badge-active { background:#d1fae5; color:#065f46; border-radius:12px; padding:2px 10px; font-size:0.78rem; font-weight:600; }
.badge-inactive { background:#fee2e2; color:#991b1b; border-radius:12px; padding:2px 10px; font-size:0.78rem; font-weight:600; }
.dept-group { font-size:0.78rem; color:#888; display:block; margin-top:2px; }
.btn-sm { border:none; border-radius:6px; padding:4px 12px; font-size:0.78rem; cursor:pointer; font-weight:600; }
.btn-edit-sm { background:#e0e7ff; color:#3730a3; }
.btn-edit-sm:hover { background:#c7d2fe; }
.btn-toggle-sm { background:#fef9c3; color:#854d0e; }
.btn-toggle-sm:hover { background:#fde68a; }
.btn-del-sm { background:#fee2e2; color:#991b1b; }
.btn-del-sm:hover { background:#fecaca; }
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:1000; align-items:center; justify-content:center; }
.modal-overlay.open { display:flex; }
.modal-box { background:#fff; border-radius:14px; padding:28px 32px; width:480px; max-width:95vw; box-shadow:0 8px 32px rgba(0,0,0,.18); }
.modal-box h4 { font-size:1rem; font-weight:700; color:#1a2a5e; margin:0 0 18px; }
.modal-field { margin-bottom:14px; }
.modal-field label { display:block; font-size:0.8rem; font-weight:600; color:#444; margin-bottom:4px; }
.modal-field input, .modal-field textarea, .modal-field select { width:100%; border:1px solid #ddd; border-radius:6px; padding:8px 10px; font-size:0.88rem; box-sizing:border-box; }
.modal-actions { display:flex; gap:10px; margin-top:18px; }
.btn-save { background:#e31837; color:#fff; border:none; border-radius:6px; padding:8px 22px; font-weight:600; cursor:pointer; font-size:0.88rem; }
.btn-save:hover { background:#c01530; }
.btn-cancel-modal { background:#f1f5f9; border:1px solid #ddd; border-radius:6px; padding:8px 18px; cursor:pointer; font-size:0.88rem; }
.empty-state { text-align:center; padding:40px 20px; color:#aaa; }
.filter-bar { display:flex; gap:12px; margin-bottom:18px; flex-wrap:wrap; }
.filter-bar select { border:1px solid #ddd; border-radius:6px; padding:7px 12px; font-size:0.85rem; min-width:160px; }
.breadcrumbs { font-size:0.82rem; color:#888; margin-bottom:14px; }
.breadcrumbs a { color:#1a2a5e; text-decoration:none; }
.breadcrumbs a:hover { text-decoration:underline; }
</style>
    <div class="breadcrumbs">
        <a asp-controller="MasterData" asp-action="Department">Master Data → Departments</a> /
        <strong>LOB (Line of Business)</strong>
    </div>
    <div class="master-header">
        <div>
            <div class="page-title">Line of Business (LOB)</div>
            <div class="page-sub">Manage LOBs mapped to Departments. Each LOB maps to a deployment within a department.</div>
        </div>
        <button class="btn-add" onclick="openAddModal()">+ Add LOB</button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div style="background:#d1fae5;border:1px solid #6ee7b7;border-radius:8px;padding:10px 16px;margin-bottom:16px;color:#065f46;font-size:0.88rem;">
            ✓ @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:10px 16px;margin-bottom:16px;color:#991b1b;font-size:0.88rem;">
            ⚠ @TempData["Error"]
        </div>
    }

    <!-- Filter by department -->
    <div class="filter-bar">
        <select id="deptFilter" onchange="filterByDept(this.value)">
            <option value="">All Departments</option>
            @foreach (var d in departments)
            {
                <option value="@d">@d</option>
            }
        </select>
        <span style="font-size:0.83rem;color:#888;align-self:center;">@Model.Count LOB(s) total</span>
    </div>

    <div class="master-card">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div style="font-size:2rem;margin-bottom:8px;">🗂</div>
                <div>No LOBs configured yet. Add your first LOB to get started.</div>
            </div>
        }
        else
        {
            <table class="master-table" id="lobTable">
                <thead>
                    <tr>
                        <th>LOB Name</th>
                        <th>Department</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lob in Model)
                    {
                        <tr data-dept="@lob.DepartmentName">
                            <td><strong>@lob.Name</strong></td>
                            <td><span class="badge-active" style="background:#dbeafe;color:#1e40af;">@lob.DepartmentName</span></td>
                            <td style="color:#666;max-width:220px;">@(lob.Description ?? "—")</td>
                            <td>
                                <span class="@(lob.IsActive ? "badge-active" : "badge-inactive")">
                                    @(lob.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td style="display:flex;gap:6px;flex-wrap:wrap;">
                                <button class="btn-sm btn-edit-sm"
                                        data-id="@lob.Id"
                                        data-name="@lob.Name"
                                        data-dept="@lob.DepartmentName"
                                        data-desc="@(lob.Description ?? "")"
                                        data-active="@(lob.IsActive ? "true" : "false")"
                                        onclick="openEditModal(this)">Edit</button>
                                <form asp-action="ToggleLob" asp-route-id="@lob.Id" method="post" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-sm btn-toggle-sm">@(lob.IsActive ? "Deactivate" : "Activate")</button>
                                </form>
                                @if (User.IsInRole("SuperAdmin"))
                                {
                                    <form asp-action="DeleteLob" asp-route-id="@lob.Id" method="post" style="margin:0;"
                                          data-lobname="@lob.Name"
                                          onsubmit="return confirm('Delete LOB \'' + this.dataset.lobname + '\'? This cannot be undone.')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-sm btn-del-sm">Delete</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</main>
</div>

<!-- Add LOB Modal -->
<div class="modal-overlay" id="addModal">
    <div class="modal-box">
        <h4>Add New LOB</h4>
        <form asp-action="CreateLob" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-field">
                <label>Department <span style="color:#e31837">*</span></label>
                <select name="departmentName" required>
                    <option value="">— Select Department —</option>
                    @foreach (var d in departments)
                    {
                        <option value="@d">@d</option>
                    }
                </select>
            </div>
            <div class="modal-field">
                <label>LOB Name <span style="color:#e31837">*</span></label>
                <input type="text" name="name" required placeholder="e.g. Retail Banking" maxlength="100" />
            </div>
            <div class="modal-field">
                <label>Description</label>
                <textarea name="description" rows="2" placeholder="Brief description…" maxlength="300"></textarea>
            </div>
            <div class="modal-actions">
                <button type="submit" class="btn-save">Add LOB</button>
                <button type="button" class="btn-cancel-modal" onclick="closeModal('addModal')">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit LOB Modal -->
<div class="modal-overlay" id="editModal">
    <div class="modal-box">
        <h4>Edit LOB</h4>
        <form id="editForm" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-field">
                <label>Department <span style="color:#e31837">*</span></label>
                <select id="editDeptName" name="departmentName" required>
                    <option value="">— Select Department —</option>
                    @foreach (var d in departments)
                    {
                        <option value="@d">@d</option>
                    }
                </select>
            </div>
            <div class="modal-field">
                <label>LOB Name <span style="color:#e31837">*</span></label>
                <input type="text" id="editName" name="name" required maxlength="100" />
            </div>
            <div class="modal-field">
                <label>Description</label>
                <textarea id="editDesc" name="description" rows="2" maxlength="300"></textarea>
            </div>
            <div class="modal-field">
                <label>
                    <input type="checkbox" id="editActive" name="isActive" value="true" style="width:auto;margin-right:6px;" />
                    Active
                </label>
            </div>
            <div class="modal-actions">
                <button type="submit" class="btn-save">Save Changes</button>
                <button type="button" class="btn-cancel-modal" onclick="closeModal('editModal')">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
const DEPARTMENTS = @Html.Raw(deptJson);

function openAddModal() { document.getElementById('addModal').classList.add('open'); }

function openEditModal(btn) {
    const id       = btn.dataset.id;
    const name     = btn.dataset.name;
    const dept     = btn.dataset.dept;
    const desc     = btn.dataset.desc;
    const isActive = btn.dataset.active === 'true';

    document.getElementById('editForm').action = '/MasterData/EditLob/' + id;
    document.getElementById('editName').value   = name;
    document.getElementById('editDesc').value   = desc;
    document.getElementById('editActive').checked = isActive;

    const deptSelect = document.getElementById('editDeptName');
    if (deptSelect) {
        for (let i = 0; i < deptSelect.options.length; i++) {
            deptSelect.options[i].selected = deptSelect.options[i].value === dept;
        }
    }
    document.getElementById('editModal').classList.add('open');
}

function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// Click-outside to close
['addModal','editModal'].forEach(id => {
    document.getElementById(id).addEventListener('click', e => {
        if (e.target.id === id) closeModal(id);
    });
});

// Dept filter
function filterByDept(dept) {
    document.querySelectorAll('#lobTable tbody tr').forEach(row => {
        row.style.display = (!dept || row.dataset.dept === dept) ? '' : 'none';
    });
}
</script>
}
