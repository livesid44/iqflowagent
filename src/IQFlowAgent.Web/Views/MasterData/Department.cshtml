@model IEnumerable<IQFlowAgent.Web.Models.MasterDepartment>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Department Master Data";
    ViewData["ActivePage"] = "masterdata";
}
@await Html.PartialAsync("_AppShell", new ViewDataDictionary(ViewData))

<main class="app-main">
    <div class="page-header">
        <div>
            <div class="page-title">Department Master Data</div>
            <div class="page-sub">Manage the list of departments available in intake forms</div>
        </div>
        <button class="btn-add-dept" onclick="document.getElementById('addModal').style.display='flex'">
            + Add Department
        </button>
    </div>

    <style>
        .page-header   { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:24px; }
        .btn-add-dept  { background:#e31837; color:#fff; border:none; border-radius:8px; padding:10px 22px; font-size:0.9rem; font-weight:600; cursor:pointer; }
        .btn-add-dept:hover { background:#c01530; }
        .dept-card     { background:#fff; border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,0.07); overflow:hidden; }
        .dept-table    { width:100%; border-collapse:collapse; }
        .dept-table th { background:#f8faff; font-size:0.78rem; color:#666; text-transform:uppercase; letter-spacing:.05em; padding:12px 16px; text-align:left; border-bottom:1px solid #e9ecf5; }
        .dept-table td { padding:12px 16px; font-size:0.88rem; color:#333; border-bottom:1px solid #f0f3f9; vertical-align:middle; }
        .dept-table tr:last-child td { border-bottom:none; }
        .dept-table tr:hover td { background:#fafbff; }
        .badge-active   { background:#d1fae5; color:#065f46; padding:3px 10px; border-radius:20px; font-size:0.75rem; font-weight:600; }
        .badge-inactive { background:#fee2e2; color:#991b1b; padding:3px 10px; border-radius:20px; font-size:0.75rem; font-weight:600; }
        .action-btns   { display:flex; gap:8px; }
        .btn-edit-sm   { background:#f1f5f9; border:1px solid #ddd; color:#555; border-radius:6px; padding:5px 12px; font-size:0.8rem; cursor:pointer; }
        .btn-edit-sm:hover { background:#e2e8f0; }
        .btn-del-sm    { background:#fff0f0; border:1px solid #fecaca; color:#b91c1c; border-radius:6px; padding:5px 12px; font-size:0.8rem; cursor:pointer; }
        .btn-del-sm:hover { background:#fee2e2; }
        .btn-toggle-sm { background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; border-radius:6px; padding:5px 12px; font-size:0.8rem; cursor:pointer; }
        .btn-toggle-sm.deactivate { background:#fff7ed; border-color:#fed7aa; color:#9a3412; }
        /* Modal */
        .modal-overlay  { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:1000; align-items:center; justify-content:center; }
        .modal-box      { background:#fff; border-radius:14px; padding:32px; width:440px; max-width:95%; box-shadow:0 8px 32px rgba(0,0,0,0.18); }
        .modal-title    { font-size:1.05rem; font-weight:700; color:#1a2a5e; margin-bottom:20px; }
        .modal-field    { margin-bottom:16px; }
        .modal-field label  { display:block; font-size:0.82rem; font-weight:600; color:#444; margin-bottom:5px; }
        .modal-field input, .modal-field textarea, .modal-field select {
            width:100%; border:1px solid #ddd; border-radius:7px; padding:9px 12px; font-size:0.9rem;
            color:#333; box-sizing:border-box;
        }
        .modal-actions  { display:flex; gap:10px; justify-content:flex-end; margin-top:8px; }
        .btn-save       { background:#e31837; color:#fff; border:none; border-radius:7px; padding:9px 24px; font-size:0.9rem; font-weight:600; cursor:pointer; }
        .btn-save:hover { background:#c01530; }
        .btn-cancel-modal { background:#f1f5f9; border:1px solid #ddd; color:#555; border-radius:7px; padding:9px 18px; font-size:0.9rem; cursor:pointer; }
        .toast-success  { background:#d1fae5; border:1px solid #6ee7b7; color:#065f46; padding:12px 16px; border-radius:8px; margin-bottom:16px; font-size:0.88rem; }
        .toast-error    { background:#fee2e2; border:1px solid #fca5a5; color:#991b1b; padding:12px 16px; border-radius:8px; margin-bottom:16px; font-size:0.88rem; }
    </style>

    @if (TempData["Success"] != null)
    {
        <div class="toast-success">✓ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-error">⚠ @TempData["Error"]</div>
    }

    <div class="dept-card">
        <table class="dept-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Department Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int rowNum = 1; }
                @foreach (var dept in Model.OrderBy(d => d.Name))
                {
                    <tr>
                        <td style="color:#999">@(rowNum++)</td>
                        <td><strong>@dept.Name</strong></td>
                        <td style="color:#666">@(dept.Description ?? "—")</td>
                        <td>
                            @if (dept.IsActive)
                            {
                                <span class="badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge-inactive">Inactive</span>
                            }
                        </td>
                        <td style="color:#888">@dept.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="action-btns">
                                <button class="btn-edit-sm"
                                    onclick="openEdit(@dept.Id, @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dept.Name)), @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dept.Description ?? "")), @(dept.IsActive ? "true" : "false"))">
                                    Edit
                                </button>
                                <form asp-action="ToggleDepartment" asp-route-id="@dept.Id" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-toggle-sm @(dept.IsActive ? "deactivate" : "")">
                                        @(dept.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                                @if (User.IsInRole("SuperAdmin"))
                                {
                                    <form asp-action="DeleteDepartment" asp-route-id="@dept.Id" method="post" style="display:inline"
                                          onsubmit="return confirm('Delete department \'@dept.Name\'? This cannot be undone.')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-del-sm">Delete</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" style="text-align:center;padding:32px;color:#aaa">No departments found. Add your first department above.</td></tr>
                }
            </tbody>
        </table>
    </div>
</main>
</div>

<!-- Add Department Modal -->
<div class="modal-overlay" id="addModal">
    <div class="modal-box">
        <div class="modal-title">Add Department</div>
        <form asp-action="CreateDepartment" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-field">
                <label>Department Name <span style="color:#e31837">*</span></label>
                <input type="text" name="name" required maxlength="100" placeholder="e.g. Finance" />
            </div>
            <div class="modal-field">
                <label>Description (optional)</label>
                <textarea name="description" rows="2" placeholder="Brief description..."></textarea>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel-modal" onclick="document.getElementById('addModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-save">Save Department</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Department Modal -->
<div class="modal-overlay" id="editModal">
    <div class="modal-box">
        <div class="modal-title">Edit Department</div>
        <form id="editForm" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-field">
                <label>Department Name <span style="color:#e31837">*</span></label>
                <input type="text" id="editName" name="name" required maxlength="100" />
            </div>
            <div class="modal-field">
                <label>Description (optional)</label>
                <textarea id="editDesc" name="description" rows="2"></textarea>
            </div>
            <div class="modal-field">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                    <input type="checkbox" id="editActive" name="isActive" value="true" />
                    <span>Active</span>
                </label>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel-modal" onclick="document.getElementById('editModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-save">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
function openEdit(id, name, desc, isActive) {
    document.getElementById('editName').value    = name;
    document.getElementById('editDesc').value    = desc;
    document.getElementById('editActive').checked = isActive;
    document.getElementById('editForm').action   = '/MasterData/EditDepartment/' + id;
    document.getElementById('editModal').style.display = 'flex';
}
// Close modal on backdrop click
['addModal','editModal'].forEach(id => {
    document.getElementById(id).addEventListener('click', function(e) {
        if (e.target === this) this.style.display = 'none';
    });
});
</script>
