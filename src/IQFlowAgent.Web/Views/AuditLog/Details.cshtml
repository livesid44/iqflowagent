@model IQFlowAgent.Web.Models.AuditLog
@using IQFlowAgent.Web.Controllers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Audit Log — Details";
    ViewData["ActivePage"] = "auditlog";

    var paired       = ViewBag.PairedLogs   as List<IQFlowAgent.Web.Models.AuditLog> ?? [];
    var piiFindings  = ViewBag.PiiFindings  as List<PiiAuditFinding>                 ?? [];
    var intake       = ViewBag.LinkedIntake as IQFlowAgent.Web.Models.IntakeRecord;
}
@await Html.PartialAsync("_AppShell", new ViewDataDictionary(ViewData))

<main class="app-main">
<div class="page-title">Audit Log — Entry #@Model.Id</div>
<div class="page-sub">
    <a href="/AuditLog" style="color:#888;text-decoration:none;">← Back to Audit Log</a>
    &nbsp;|&nbsp;
    <a href="/AuditLog/Sequence/@Model.CorrelationId" style="color:#6366f1;">View full sequence (@Model.CorrelationId)</a>
</div>

<style>
    .detail-card       { background:#fff; border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,.07); padding:24px 28px; margin-bottom:20px; }
    .detail-card h3    { font-size:0.9rem; font-weight:700; color:#1a2a5e; margin-bottom:14px; padding-bottom:8px; border-bottom:1px solid #e9ecf5; }
    .kv-grid           { display:grid; grid-template-columns:160px 1fr; gap:8px 0; font-size:0.85rem; }
    .kv-key            { color:#888; padding:4px 0; }
    .kv-val            { color:#333; padding:4px 0; font-weight:500; }
    .badge             { display:inline-block; padding:3px 10px; border-radius:20px; font-size:0.76rem; font-weight:600; }
    .badge-success     { background:#d1fae5; color:#065f46; }
    .badge-mock        { background:#e0e7ff; color:#3730a3; }
    .badge-error       { background:#fee2e2; color:#991b1b; }
    .badge-blocked     { background:#fef3c7; color:#92400e; }
    .badge-redacted    { background:#fce7f3; color:#9d174d; }
    .badge-clean       { background:#d1fae5; color:#065f46; }
    .badge-default     { background:#f1f5f9; color:#64748b; }

    .pii-section       { background:#fffbeb; border:1px solid #fde68a; border-radius:10px; padding:16px 18px; }
    .pii-section.pass  { background:#f0fdf4; border-color:#86efac; }
    .pii-section.blocked{ background:#fef9ee; border-color:#fbbf24; }
    .pii-header        { display:flex; align-items:center; gap:10px; margin-bottom:12px; }
    .pii-icon          { font-size:1.4rem; }
    .pii-title         { font-size:0.95rem; font-weight:700; }
    .finding-table     { width:100%; border-collapse:collapse; margin-top:8px; }
    .finding-table th  { font-size:0.76rem; color:#666; text-transform:uppercase; padding:8px 12px; background:#f9fafb; border-bottom:1px solid #e5e7eb; text-align:left; }
    .finding-table td  { font-size:0.83rem; padding:8px 12px; border-bottom:1px solid #f3f4f6; }
    .finding-table tr:last-child td { border-bottom:none; }
    .entity-chip       { display:inline-block; padding:2px 9px; border-radius:12px; font-size:0.76rem; background:#fee2e2; color:#991b1b; font-weight:600; }
    .masked-val        { font-family:monospace; color:#6b7280; }

    .paired-item       { display:flex; align-items:center; gap:10px; padding:10px 14px; border-radius:8px; background:#f8faff; margin-bottom:6px; font-size:0.83rem; }
    .ev-llm            { color:#1a2a5e; font-weight:600; }
    .ev-pii            { color:#7c3aed; font-weight:600; }
    .intake-link       { display:inline-block; background:#f0f4ff; color:#1a2a5e; border-radius:6px; padding:4px 14px; font-size:0.83rem; text-decoration:none; font-weight:600; }
    .intake-link:hover { background:#e0e7ff; }
    .url-wrap          { font-family:monospace; font-size:0.78rem; color:#6366f1; background:#f1f5f9; border-radius:5px; padding:3px 8px; word-break:break-all; }
    .err-box           { background:#fee2e2; color:#991b1b; border-radius:7px; padding:10px 14px; font-size:0.82rem; margin-top:4px; }
</style>

<!-- ── Main details card ── -->
<div class="detail-card">
    <h3>Event Details</h3>
    <div class="kv-grid">
        <span class="kv-key">Event Type</span>
        <span class="kv-val @(Model.EventType == "LlmCall" ? "ev-llm" : "ev-pii")">@Model.EventType</span>

        <span class="kv-key">Call Site</span>
        <span class="kv-val">@Model.CallSite</span>

        <span class="kv-key">Outcome</span>
        <span class="kv-val">
            @{
                string outClass = Model.Outcome switch {
                    "Success"      => "badge-success",
                    "MockResponse" => "badge-mock",
                    "Error"        => "badge-error",
                    "Blocked"      => "badge-blocked",
                    "Redacted"     => "badge-redacted",
                    "Clean"        => "badge-clean",
                    _              => "badge-default"
                };
            }
            <span class="badge @outClass">@Model.Outcome</span>
            @if (Model.IsMocked) { <span class="badge badge-mock" style="margin-left:4px;">Mock</span> }
            @if (Model.WasBlocked) { <span class="badge badge-blocked" style="margin-left:4px;">🚫 Blocked</span> }
        </span>

        <span class="kv-key">Time</span>
        <span class="kv-val">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm:ss") UTC</span>

        <span class="kv-key">Correlation ID</span>
        <span class="kv-val"><a href="/AuditLog/Sequence/@Model.CorrelationId" style="color:#6366f1;text-decoration:none;font-family:monospace;">@Model.CorrelationId</a></span>

        @if (Model.HttpStatusCode.HasValue)
        {
            <span class="kv-key">HTTP Status</span>
            <span class="kv-val">@Model.HttpStatusCode</span>
        }

        @if (Model.DurationMs.HasValue && Model.DurationMs > 0)
        {
            <span class="kv-key">Duration</span>
            <span class="kv-val">@Model.DurationMs ms</span>
        }

        @if (!string.IsNullOrWhiteSpace(Model.RequestUrl))
        {
            <span class="kv-key">Request URL</span>
            <span class="kv-val"><span class="url-wrap">@Model.RequestUrl</span></span>
        }

        @if (intake != null)
        {
            <span class="kv-key">Linked Intake</span>
            <span class="kv-val">
                <a href="/Intake/Details/@intake.Id" class="intake-link">@intake.IntakeId — @intake.ProcessName</a>
            </span>
        }

        @if (!string.IsNullOrWhiteSpace(Model.UserId))
        {
            <span class="kv-key">User</span>
            <span class="kv-val">@Model.UserId</span>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="err-box" style="margin-top:12px;">⚠ @Model.ErrorMessage</div>
    }
</div>

<!-- ── PII/SPII Scan Card ── -->
@if (Model.EventType == "PiiScan")
{
    bool isPiiPass    = Model.PiiScanStatus == "Pass";
    bool isPiiBlocked = Model.PiiScanStatus == "Blocked";
    string piiSection = isPiiPass ? "pass" : isPiiBlocked ? "blocked" : "";

    <div class="detail-card">
        <h3>PII / SPII Scan Result</h3>
        <div class="pii-section @piiSection">
            <div class="pii-header">
                <span class="pii-icon">@(isPiiPass ? "✅" : isPiiBlocked ? "🚫" : "⚠️")</span>
                <div>
                    <div class="pii-title">
                        Scan Status: @Model.PiiScanStatus
                        @if (Model.PiiFindingCount > 0)
                        {
                            <span style="font-weight:400;color:#666;margin-left:8px;">— @Model.PiiFindingCount finding(s)</span>
                        }
                    </div>
                    <div style="font-size:0.8rem;color:#666;margin-top:2px;">
                        @if (isPiiPass) { <span>No PII/SPII detected — content forwarded to LLM unchanged.</span> }
                        else if (isPiiBlocked) { <span>Content was <strong>blocked</strong> — the LLM call was aborted.</span> }
                        else { <span>PII detected and <strong>redacted</strong> before forwarding to the LLM. Placeholders inserted in place of sensitive values.</span> }
                    </div>
                </div>
            </div>

            @if (piiFindings.Count > 0)
            {
                <table class="finding-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Entity Type</th>
                            <th>Matched Value (masked)</th>
                            <th>Placeholder Used</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (f, idx) in piiFindings.Select((f, i) => (f, i + 1)))
                        {
                            <tr>
                                <td style="color:#94a3b8;">@idx</td>
                                <td><span class="entity-chip">@f.EntityType</span></td>
                                <td><span class="masked-val">@f.MatchedText</span></td>
                                <td><span class="masked-val" style="color:#6366f1;">[@f.EntityType.Replace(" ", "_").Replace("/", "_").ToUpperInvariant()]</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

<!-- ── Paired logs in this correlation ── -->
@if (paired.Count > 0)
{
    <div class="detail-card">
        <h3>Related Events (same correlation ID)</h3>
        @foreach (var p in paired)
        {
            string pOutClass = p.Outcome switch {
                "Success"      => "badge-success",
                "MockResponse" => "badge-mock",
                "Error"        => "badge-error",
                "Blocked"      => "badge-blocked",
                "Redacted"     => "badge-redacted",
                "Clean"        => "badge-clean",
                _              => "badge-default"
            };
            <div class="paired-item">
                <span class="@(p.EventType == "LlmCall" ? "ev-llm" : "ev-pii")">@p.EventType</span>
                <span style="color:#888;font-size:0.8rem;">@p.CallSite</span>
                <span class="badge @pOutClass">@p.Outcome</span>
                @if (p.DurationMs.HasValue && p.DurationMs > 0)
                {
                    <span style="color:#94a3b8;font-size:0.78rem;">@p.DurationMs ms</span>
                }
                <span style="color:#94a3b8;font-size:0.78rem;margin-left:auto;">@p.CreatedAt.ToString("HH:mm:ss")</span>
                <a href="/AuditLog/Details/@p.Id" style="color:#6366f1;font-size:0.78rem;">Details</a>
            </div>
        }
    </div>
}

</main>
</div>
