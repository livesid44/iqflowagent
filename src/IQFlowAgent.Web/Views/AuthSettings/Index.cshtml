@model IQFlowAgent.Web.Models.AuthSettings
@{
    Layout = "_Layout";
    ViewData["Title"] = "Auth Settings";
    ViewData["ActivePage"] = "authsettings";
}

<style>
    .card-panel {
        background: #fff; border-radius: 12px; padding: 28px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07); max-width: 700px;
    }
    .auth-mode-card {
        border: 2px solid #e8ecf5; border-radius: 10px; padding: 16px 20px;
        margin-bottom: 12px; cursor: pointer; transition: all 0.2s;
    }
    .auth-mode-card:hover { border-color: #1a2a5e; }
    .auth-mode-card.selected { border-color: #1a2a5e; background: #f0f4ff; }
    .auth-mode-title { font-weight: 600; color: #1a2a5e; margin-bottom: 2px; }
    .auth-mode-desc { font-size: 0.82rem; color: #888; }
    .ldap-config { background: #f8faff; border: 1px solid #dbe4ff; border-radius: 10px; padding: 20px; margin-top: 16px; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: 0.85rem; color: #555; margin-bottom: 4px; font-weight: 500; }
    .form-group input[type=text], .form-group input[type=password], .form-group input[type=number] {
        width: 100%; border: 1px solid #ddd; border-radius: 6px; padding: 8px 10px; font-size: 0.9rem;
    }
    .form-group input:focus { border-color: #1a2a5e; outline: none; }
    .btn-save {
        background: #1a2a5e; border: none; color: #fff;
        border-radius: 8px; padding: 10px 24px; font-size: 0.95rem;
        cursor: pointer; transition: background 0.2s;
    }
    .btn-save:hover { background: #294993; }
    .form-row { display: flex; gap: 16px; }
    .form-row .form-group { flex: 1; }
</style>

@await Html.PartialAsync("_AppShell")

<main class="app-main">
    <div class="page-title">Authentication Settings</div>
    <div class="page-sub">Configure how users authenticate to the platform</div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success py-2 small mb-3">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger py-2 small mb-3">@TempData["Error"]</div>
        }

        <div class="card-panel">
            <form asp-action="Save" asp-controller="AuthSettings" method="post">
                @Html.AntiForgeryToken()
                <h6 style="color:#1a2a5e;font-weight:700;margin-bottom:14px;">Authentication Mode</h6>

                <div class="auth-mode-card @(Model.AuthMode == "AppPassword" ? "selected" : "")" onclick="selectMode('AppPassword')">
                    <label style="display:flex;align-items:center;gap:10px;cursor:pointer;">
                        <input type="radio" name="AuthMode" value="AppPassword" @(Model.AuthMode == "AppPassword" ? "checked" : "") onchange="updateLdap()" />
                        <div>
                            <div class="auth-mode-title"><i class="bi bi-key"></i> App-Level Password Authentication</div>
                            <div class="auth-mode-desc">Users are managed within the application with bcrypt-hashed passwords.</div>
                        </div>
                    </label>
                </div>

                <div class="auth-mode-card @(Model.AuthMode == "LDAP" ? "selected" : "")" onclick="selectMode('LDAP')">
                    <label style="display:flex;align-items:center;gap:10px;cursor:pointer;">
                        <input type="radio" name="AuthMode" value="LDAP" @(Model.AuthMode == "LDAP" ? "checked" : "") onchange="updateLdap()" />
                        <div>
                            <div class="auth-mode-title"><i class="bi bi-diagram-3"></i> LDAP Authentication</div>
                            <div class="auth-mode-desc">Authenticate users against an LDAP / Active Directory server.</div>
                        </div>
                    </label>
                </div>

                <div class="ldap-config" id="ldapConfig" style="display: @(Model.AuthMode == "LDAP" ? "block" : "none");">
                    <h6 style="color:#1a2a5e;margin-bottom:14px;">LDAP Configuration</h6>
                    <div class="form-row">
                        <div class="form-group">
                            <label>LDAP Server</label>
                            <input type="text" name="LdapServer" value="@Model.LdapServer" placeholder="e.g. ldap.example.com" />
                        </div>
                        <div class="form-group" style="max-width:120px;">
                            <label>Port</label>
                            <input type="number" name="LdapPort" value="@Model.LdapPort" placeholder="389" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Base DN</label>
                        <input type="text" name="LdapBaseDn" value="@Model.LdapBaseDn" placeholder="e.g. dc=example,dc=com" />
                    </div>
                    <div class="form-group">
                        <label>Bind DN</label>
                        <input type="text" name="LdapBindDn" value="@Model.LdapBindDn" placeholder="e.g. cn=admin,dc=example,dc=com" />
                    </div>
                    <div class="form-group">
                        <label>Bind Password</label>
                        <input type="password" name="LdapBindPassword" value="@Model.LdapBindPassword" placeholder="Service account password" />
                    </div>
                    <div class="form-group">
                        <label>Search Filter</label>
                        <input type="text" name="LdapSearchFilter" value="@Model.LdapSearchFilter" placeholder="(sAMAccountName={0})" />
                    </div>
                    <div class="form-group">
                        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                            <input type="checkbox" name="LdapUseSsl" value="true" @(Model.LdapUseSsl ? "checked" : "") />
                            Use SSL (LDAPS)
                        </label>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn-save"><i class="bi bi-save"></i> Save Settings</button>
                </div>
            </form>
        </div>
</main>
</div><!-- close app-layout -->

@section Scripts {
<script>
function updateLdap() {
    var ldap = document.querySelector('input[name="AuthMode"][value="LDAP"]').checked;
    document.getElementById('ldapConfig').style.display = ldap ? 'block' : 'none';
    document.querySelectorAll('.auth-mode-card').forEach(function(c) { c.classList.remove('selected'); });
    document.querySelectorAll('input[name="AuthMode"]').forEach(function(r) {
        if (r.checked) r.closest('.auth-mode-card').classList.add('selected');
    });
}
function selectMode(mode) {
    document.querySelector('input[name="AuthMode"][value="' + mode + '"]').checked = true;
    updateLdap();
}
</script>
}
