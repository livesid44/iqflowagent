@model IQFlowAgent.Web.Models.TenantAiSettings
@{
    ViewData["Title"] = "AI & Storage Settings";
    var tenant = ViewBag.Tenant as IQFlowAgent.Web.Models.Tenant;
}
@await Html.PartialAsync("_AppShell", new ViewDataDictionary(ViewData) { { "ActivePage", "tenantaisettings" } })
<main class="app-main">
    <div class="page-title">AI & Storage Settings</div>
    <div class="page-subtitle">Configure Azure OpenAI and Azure Blob Storage for <strong>@tenant?.Name</strong></div>
    @if (TempData["Success"] != null) { <div class="alert-success-bar">@TempData["Success"]</div> }

    <form asp-action="Save" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="TenantId" />

        <div class="data-card" style="margin-bottom:24px;">
            <div class="card-header" style="font-weight:600;font-size:15px;padding:16px 20px;border-bottom:1px solid #eee;">Azure OpenAI Settings</div>
            <div style="padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div style="grid-column:1/-1;"><label>Endpoint URL</label><input asp-for="AzureOpenAIEndpoint" class="form-input" placeholder="https://your-resource.cognitiveservices.azure.com/" /></div>
                <div><label>API Key</label><input asp-for="AzureOpenAIApiKey" class="form-input" type="password" placeholder="Your Azure OpenAI API key" autocomplete="off" /></div>
                <div><label>Deployment Name</label><input asp-for="AzureOpenAIDeploymentName" class="form-input" placeholder="gpt-4o" /></div>
                <div><label>API Version</label><input asp-for="AzureOpenAIApiVersion" class="form-input" placeholder="2025-01-01-preview" /></div>
                <div><label>Max Output Tokens</label><input asp-for="AzureOpenAIMaxTokens" class="form-input" type="number" min="100" max="16000" /></div>
            </div>
        </div>

        <div class="data-card" style="margin-bottom:24px;">
            <div class="card-header" style="font-weight:600;font-size:15px;padding:16px 20px;border-bottom:1px solid #eee;">Azure Blob Storage Settings</div>
            <div style="padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div style="grid-column:1/-1;"><label>Connection String</label><input asp-for="AzureStorageConnectionString" class="form-input" type="password" placeholder="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;" autocomplete="off" /></div>
                <div><label>Container Name</label><input asp-for="AzureStorageContainerName" class="form-input" placeholder="intakes" /></div>
            </div>
        </div>

        @if (Model.UpdatedAt != default) {
            <p style="color:#888;font-size:12px;">Last updated: @Model.UpdatedAt.ToString("dd MMM yyyy HH:mm") by @Model.UpdatedByUserId</p>
        }

        <button type="submit" class="btn-primary">Save Settings</button>
    </form>
</main>
</div>
