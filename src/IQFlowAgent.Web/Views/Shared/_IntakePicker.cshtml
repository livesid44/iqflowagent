@* _IntakePicker.cshtml — reusable intake selector with filter engine.
   Required ViewBag keys (set by AnalysisController / TaskController):
     IntakePickerIntakes      List<IntakeRecord>  — filtered list to display
     IntakePickerSelected     int?                — currently selected intake ID
     IntakePickerSearch       string?
     IntakePickerCountry      string?
     IntakePickerBusinessUnit string?
     IntakePickerProcessType  string?
     IntakePickerController   string              — e.g. "Analysis"
     IntakePickerAction       string              — e.g. "Index"
     Countries                List<string>
     BusinessUnits            List<string>
     ProcessTypes             List<string>
*@
@using IQFlowAgent.Web.Models
@{
    var pickerIntakes = ViewBag.IntakePickerIntakes  as List<IntakeRecord> ?? new List<IntakeRecord>();
    int? selectedId   = ViewBag.IntakePickerSelected is int sv ? (int?)sv : null;
    var srch          = ViewBag.IntakePickerSearch       as string ?? "";
    var cntry         = ViewBag.IntakePickerCountry      as string ?? "";
    var bu            = ViewBag.IntakePickerBusinessUnit as string ?? "";
    var pt            = ViewBag.IntakePickerProcessType  as string ?? "";
    var ctrl          = ViewBag.IntakePickerController   as string ?? "Analysis";
    var act           = ViewBag.IntakePickerAction       as string ?? "Index";
    var countries     = ViewBag.Countries     as List<string> ?? new List<string>();
    var busUnits      = ViewBag.BusinessUnits as List<string> ?? new List<string>();
    var procTypes     = ViewBag.ProcessTypes  as List<string> ?? new List<string>();
    bool hasFilters   = !string.IsNullOrEmpty(srch) || !string.IsNullOrEmpty(cntry)
                        || !string.IsNullOrEmpty(bu) || !string.IsNullOrEmpty(pt);

    string StatusColor(string s) => s switch {
        "Complete"  => "#059669",
        "Analyzing" => "#d97706",
        "Submitted" => "#d97706",
        "Error"     => "#e31837",
        _           => "#6b7280"
    };
}

<style>
    /* ── Picker panel ─────────────────────────────────── */
    .intake-picker {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.07);
        margin-bottom: 24px;
        overflow: hidden;
    }
    .picker-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 20px;
        background: #f8faff;
        border-bottom: 1px solid #eef0f7;
    }
    .picker-header-title {
        font-size: .88rem; font-weight: 700; color: #1a2a5e;
        display: flex; align-items: center; gap: 7px;
    }
    .picker-header-title .bi { color: #e31837; }
    .picker-count-badge {
        background: #e8ecf7; color: #1a2a5e;
        border-radius: 20px; padding: 2px 10px;
        font-size: .74rem; font-weight: 700;
    }
    /* ── Filter bar ───────────────────────────────────── */
    .picker-filter-bar {
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
        padding: 12px 20px; border-bottom: 1px solid #f0f0f0;
    }
    .pf-search {
        flex: 1; min-width: 180px; max-width: 300px;
        border: 1px solid #e0e0e0; border-radius: 7px;
        padding: 7px 12px; font-size: .84rem; color: #333;
        outline: none;
    }
    .pf-search:focus { border-color: #1a2a5e; }
    .pf-select {
        border: 1px solid #e0e0e0; border-radius: 7px;
        padding: 7px 10px; font-size: .83rem; color: #333;
        background: #fff; outline: none; cursor: pointer;
    }
    .pf-select:focus { border-color: #1a2a5e; }
    .pf-btn-search {
        background: #1a2a5e; color: #fff; border: none;
        border-radius: 7px; padding: 7px 18px; font-size: .83rem;
        font-weight: 600; cursor: pointer; white-space: nowrap;
    }
    .pf-btn-search:hover { background: #142248; }
    .pf-btn-clear {
        background: #f5f6fa; color: #555;
        border: 1px solid #e0e0e0; border-radius: 7px;
        padding: 7px 14px; font-size: .83rem; cursor: pointer;
        text-decoration: none; display: inline-block; white-space: nowrap;
    }
    .pf-btn-clear:hover { background: #ececec; color: #333; }
    /* ── Cards track ──────────────────────────────────── */
    .picker-cards-track {
        display: flex; gap: 10px; overflow-x: auto;
        padding: 12px 20px 14px; scroll-snap-type: x mandatory;
    }
    .picker-cards-track::-webkit-scrollbar { height: 4px; }
    .picker-cards-track::-webkit-scrollbar-thumb { background: #d0d5e8; border-radius: 2px; }
    /* ── Intake card ──────────────────────────────────── */
    .picker-card {
        flex: 0 0 200px; scroll-snap-align: start;
        border: 2px solid #e8ecf7; border-radius: 10px;
        padding: 12px 14px; background: #fff;
        text-decoration: none; color: inherit;
        cursor: pointer; transition: border-color .15s, box-shadow .15s;
        display: block;
    }
    .picker-card:hover { border-color: #1a2a5e; box-shadow: 0 2px 10px rgba(26,42,94,.12); color: inherit; }
    .picker-card-selected { border-color: #e31837 !important; background: #fff5f7; box-shadow: 0 2px 10px rgba(227,24,55,.15); }
    .pc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px; }
    .pc-id { font-size: .7rem; font-family: monospace; color: #888; }
    .pc-dot { font-size: .8rem; }
    .pc-name { font-size: .83rem; font-weight: 600; color: #1a2a5e; line-height: 1.3; margin-bottom: 7px;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .pc-tags { display: flex; flex-wrap: wrap; gap: 4px; }
    .pc-tag {
        font-size: .67rem; background: #f0f2f8; color: #555;
        border-radius: 4px; padding: 2px 6px;
        display: flex; align-items: center; gap: 2px;
    }
    .pc-tag-bu { background: #e8f4ee; color: #1a6a3a; }
    .pc-tag-pt { background: #fef3c7; color: #92400e; }
    /* ── Empty / no-match ─────────────────────────────── */
    .picker-no-results {
        padding: 16px 0; color: #aaa; font-size: .85rem; white-space: nowrap;
    }
    .picker-no-results a { color: #e31837; }
</style>

<div class="intake-picker">
    <div class="picker-header">
        <span class="picker-header-title">
            <i class="bi bi-funnel-fill"></i> Select Intake
        </span>
        <span class="picker-count-badge">
            @pickerIntakes.Count intake@(pickerIntakes.Count == 1 ? "" : "s")
            @if (hasFilters) { <text> (filtered)</text> }
        </span>
    </div>

    <!-- Filter form -->
    <form method="get" action="@Url.Action(act, ctrl)" class="picker-filter-bar">
        @if (selectedId.HasValue)
        {
            <input type="hidden" name="selectedId" value="@selectedId" />
        }
        <input type="text" name="search" value="@srch"
               placeholder="Search ID, process name, department…" class="pf-search" />

        @if (countries.Any())
        {
            <select name="country" class="pf-select">
                <option value="">All Countries</option>
                @foreach (var c in countries)
                {
                    if (cntry == c) { <option value="@c" selected>@c</option> }
                    else            { <option value="@c">@c</option> }
                }
            </select>
        }
        @if (busUnits.Any())
        {
            <select name="businessUnit" class="pf-select">
                <option value="">All Business Units</option>
                @foreach (var b in busUnits)
                {
                    if (bu == b) { <option value="@b" selected>@b</option> }
                    else         { <option value="@b">@b</option> }
                }
            </select>
        }
        @if (procTypes.Any())
        {
            <select name="processType" class="pf-select">
                <option value="">All Types</option>
                @foreach (var p in procTypes)
                {
                    if (pt == p) { <option value="@p" selected>@p</option> }
                    else         { <option value="@p">@p</option> }
                }
            </select>
        }

        <button type="submit" class="pf-btn-search">
            <i class="bi bi-search me-1"></i>Filter
        </button>
        @if (hasFilters)
        {
            <a href="@Url.Action(act, ctrl, selectedId.HasValue ? new { selectedId } : null)"
               class="pf-btn-clear">Clear</a>
        }
    </form>

    <!-- Intake cards (horizontal scroll) -->
    <div class="picker-cards-track">
        @if (!pickerIntakes.Any())
        {
            <div class="picker-no-results">
                <i class="bi bi-inbox me-1"></i>No intakes match the current filters.
                @if (hasFilters)
                {
                    <a href="@Url.Action(act, ctrl)">Clear all filters</a>
                }
            </div>
        }
        else
        {
            @foreach (var intake in pickerIntakes)
            {
                bool isSelected = (selectedId == intake.Id);
                string cardUrl  = Url.Action(act, ctrl, new {
                    selectedId   = intake.Id,
                    search       = srch,
                    country      = cntry,
                    businessUnit = bu,
                    processType  = pt
                }) ?? "#";
                <a href="@cardUrl" class="picker-card @(isSelected ? "picker-card-selected" : "")">
                    <div class="pc-header">
                        <span class="pc-id">@intake.IntakeId</span>
                        <span class="pc-dot" style="color:@StatusColor(intake.Status);" title="@intake.Status">●</span>
                    </div>
                    <div class="pc-name">@intake.ProcessName</div>
                    <div class="pc-tags">
                        @if (!string.IsNullOrEmpty(intake.Country))
                        {
                            <span class="pc-tag"><i class="bi bi-geo-alt"></i> @intake.Country</span>
                        }
                        @if (!string.IsNullOrEmpty(intake.City))
                        {
                            <span class="pc-tag">@intake.City</span>
                        }
                        @if (!string.IsNullOrEmpty(intake.BusinessUnit))
                        {
                            <span class="pc-tag pc-tag-bu">@intake.BusinessUnit</span>
                        }
                        @if (!string.IsNullOrEmpty(intake.ProcessType))
                        {
                            <span class="pc-tag pc-tag-pt">@intake.ProcessType</span>
                        }
                    </div>
                </a>
            }
        }
    </div>
</div>
