@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    function toggleReplace() {
        document.getElementById('replaceFlag').value = 'true';
        document.getElementById('currentDocPanel').style.display = 'none';
        document.getElementById('uploadSection').style.display = 'block';
    }

    function cancelReplace() {
        document.getElementById('replaceFlag').value = 'false';
        document.getElementById('currentDocPanel').style.display = 'flex';
        document.getElementById('uploadSection').style.display = 'none';
        document.getElementById('filePreview').innerHTML = '';
    }

    function previewFile(input) {
        const preview = document.getElementById('filePreview');
        if (input.files && input.files[0]) {
            const f = input.files[0];
            const size = (f.size / 1024 / 1024).toFixed(2);
            preview.innerHTML = `<strong style="color:#1a2a5e">${f.name}</strong> — ${size} MB`;
        }
    }

    // Drag & drop
    const zone = document.getElementById('uploadZone');
    if (zone) {
        zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
        zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
        zone.addEventListener('drop', e => {
            e.preventDefault();
            zone.classList.remove('drag-over');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                const input = document.getElementById('fileInput');
                const dt = new DataTransfer();
                dt.items.add(files[0]);
                input.files = dt.files;
                previewFile(input);
            }
        });
    }
</script>

@* LOB cascade + country/city multi-select *@
<script src="~/js/country-city-data.js"></script>
<script>
    // ── LOB cascade ──────────────────────────────────────────
    const LOB_BY_DEPT = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        ((System.Collections.IEnumerable)(ViewBag.LobsByDept ?? new List<object>()))
            .Cast<dynamic>()
            .GroupBy((dynamic x) => (string)x.DepartmentName)
            .ToDictionary(g => g.Key, g => g.Select((dynamic x) => (string)x.Name).ToList())
    ));

    function onDeptChange(dept, currentLob) {
        const sel = document.getElementById('lobSelect');
        sel.innerHTML = '<option value="">— Select LOB —</option>';
        (LOB_BY_DEPT[dept] || []).forEach(lob => {
            const opt = document.createElement('option');
            opt.value = lob; opt.textContent = lob;
            if (lob === currentLob) opt.selected = true;
            sel.appendChild(opt);
        });
    }

    // Pre-populate LOB dropdown for the current department on load
    window.addEventListener('DOMContentLoaded', () => {
        const dept = document.getElementById('deptSelect').value;
        if (dept) onDeptChange(dept, @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Lob ?? "")));
    });

    // ── Multi-select component (reusable) ────────────────────
    function buildMultiSelect(containerId, inputId, dropdownId, hiddenId, list, multi, onChangeCb) {
        const container = document.getElementById(containerId);
        const textInput = document.getElementById(inputId);
        const dropdown  = document.getElementById(dropdownId);
        const hidden    = document.getElementById(hiddenId);
        let selected = hidden.value ? hidden.value.split(',').map(s => s.trim()).filter(Boolean) : [];

        function render() {
            container.querySelectorAll('.ms-tag').forEach(t => t.remove());
            selected.forEach(val => {
                const tag = document.createElement('span');
                tag.className = 'ms-tag';
                const labelNode = document.createTextNode(val + ' ');
                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'ms-tag-remove';
                removeBtn.setAttribute('aria-label', 'Remove ' + val);
                removeBtn.textContent = '×';
                removeBtn.addEventListener('click', e => {
                    e.stopPropagation();
                    selected = selected.filter(v => v !== val);
                    hidden.value = selected.join(', ');
                    render();
                    if (onChangeCb) onChangeCb(selected);
                });
                tag.appendChild(labelNode);
                tag.appendChild(removeBtn);
                container.insertBefore(tag, textInput);
            });
            hidden.value = selected.join(', ');
        }

        function showDropdown(filter) {
            const lc = filter.toLowerCase();
            const opts = list.filter(c => !selected.includes(c) && c.toLowerCase().includes(lc));
            dropdown.innerHTML = '';
            if (!opts.length) {
                const empty = document.createElement('div');
                empty.className = 'ms-empty';
                empty.textContent = 'No matches';
                dropdown.appendChild(empty);
            } else {
                opts.slice(0, 60).forEach(c => {
                    const el = document.createElement('div');
                    el.className = 'ms-option';
                    el.textContent = c;
                    el.addEventListener('mousedown', e => { e.preventDefault(); pick(c); });
                    dropdown.appendChild(el);
                });
            }
            dropdown.style.display = 'block';
        }

        function pick(val) {
            if (multi) { if (!selected.includes(val)) selected.push(val); }
            else { selected = [val]; }
            textInput.value = ''; dropdown.style.display = 'none';
            render();
            if (onChangeCb) onChangeCb(selected);
        }

        textInput.addEventListener('input',  () => showDropdown(textInput.value));
        textInput.addEventListener('focus',  () => showDropdown(textInput.value));
        textInput.addEventListener('blur',   () => setTimeout(() => { dropdown.style.display = 'none'; }, 150));
        textInput.addEventListener('keydown', e => {
            if (e.key === 'Backspace' && !textInput.value && selected.length) { selected.pop(); render(); if (onChangeCb) onChangeCb(selected); }
        });
        // textInput and dropdown are already inside container in the HTML — do not re-append
        render();
        return { getSelected: () => selected };
    }

    document.addEventListener('DOMContentLoaded', () => {

        // Lots or SDC multi-select (fixed 4-option list)
        const SDC_LOTS = [
            'Lot 1 – Global Customer Support',
            'Lot 2 – Quote to Bill',
            'Lot 3 – International Integrator',
            'Lot 4 – One Post Sales'
        ];

        // ── LOT-aware country/city filtering ────────────────────────
        const USE_LOT_FILTER  = @Html.Raw((ViewBag.UseCountryFilterByLot ?? false) ? "true" : "false");
        const LOT_COUNTRY_MAP = @Html.Raw(ViewBag.LotCountryMapJson ?? "{}");

        function getCountriesForLots(selectedLots) {
            if (!USE_LOT_FILTER || !selectedLots || selectedLots.length === 0) return COUNTRY_LIST;
            const countries = new Set();
            selectedLots.forEach(lot => { (LOT_COUNTRY_MAP[lot] || []).forEach(e => countries.add(e.country)); });
            return countries.size > 0 ? [...countries].sort() : COUNTRY_LIST;
        }

        function getCitiesForCountriesAndLots(selectedCountries, selectedLots) {
            if (!USE_LOT_FILTER || !selectedLots || selectedLots.length === 0)
                return getCitiesForCountries(selectedCountries);
            const result = new Set();
            selectedLots.forEach(lot => {
                (LOT_COUNTRY_MAP[lot] || []).filter(e => selectedCountries.includes(e.country)).forEach(e => {
                    if (e.cities && e.cities.length > 0) e.cities.forEach(c => result.add(c));
                    else (COUNTRY_CITY_MAP[e.country] || []).forEach(c => result.add(c));
                });
            });
            return result.size > 0 ? [...result].sort() : getCitiesForCountries(selectedCountries);
        }

        const lotsMs = buildMultiSelect('sdcLotsContainer', 'sdcLotsInput', 'sdcLotsDropdown', 'sdcLotsHidden',
            SDC_LOTS, true, function(selLots) {
                const newCountries = getCountriesForLots(selLots);
                countryMs = buildMultiSelect('countryContainer','countryInput','countryDropdown','countryHidden',
                    newCountries, true, function(selCts) {
                        cityMs = buildMultiSelect('cityContainer','cityInput','cityDropdown','cityHidden',
                            getCitiesForCountriesAndLots(selCts, lotsMs.getSelected()), true, null);
                    });
            });

        let countryMs = buildMultiSelect('countryContainer','countryInput','countryDropdown','countryHidden',
            getCountriesForLots(lotsMs.getSelected()), true,
            sel => { cityMs = buildMultiSelect('cityContainer','cityInput','cityDropdown','cityHidden',
                         getCitiesForCountriesAndLots(sel, lotsMs.getSelected()), true, null); }
        );
        let cityMs = buildMultiSelect('cityContainer','cityInput','cityDropdown','cityHidden',
            getCitiesForCountriesAndLots(countryMs.getSelected(), lotsMs.getSelected()), true, null);
    });
</script>

<script>
// ── XHR submit with progress overlay (handles large document replacements) ───
(function () {
    const form    = document.getElementById('intakeEditForm');
    const overlay = document.getElementById('editUploadOverlay');
    const bar     = document.getElementById('editProgressBar');
    const pct     = document.getElementById('editProgressPct');
    const title   = document.getElementById('editOverlayTitle');
    const sub     = document.getElementById('editOverlaySub');
    const btn     = document.getElementById('editSubmitBtn');

    function showOverlay() { overlay.style.display = 'flex'; }
    function hideOverlay() { overlay.style.display = 'none'; }

    function setProgress(value, label) {
        bar.style.width = value + '%';
        pct.textContent = label || (value + '%');
    }

    function showErrors(errors) {
        hideOverlay();
        if (btn) btn.disabled = false;
        const existing = document.getElementById('editXhrErrorBanner');
        if (existing) existing.remove();
        const banner = document.createElement('div');
        banner.id = 'editXhrErrorBanner';
        banner.style.cssText = 'background:#fde8ec;border:1px solid #fca5a5;border-radius:8px;' +
            'padding:12px 16px;margin-bottom:20px;color:#c01530;';
        const heading = document.createElement('strong');
        heading.textContent = 'Please fix the following errors:';
        banner.appendChild(heading);
        const ul = document.createElement('ul');
        ul.style.margin = '8px 0 0 0';
        errors.forEach(function (msg) {
            const li = document.createElement('li');
            li.textContent = msg;
            ul.appendChild(li);
        });
        banner.appendChild(ul);
        form.insertBefore(banner, form.firstChild);
        banner.scrollIntoView({ behavior: 'smooth' });
    }

    form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (btn) btn.disabled = true;

        const data = new FormData(form);
        const replacing = document.getElementById('replaceFlag') &&
                          document.getElementById('replaceFlag').value === 'true' &&
                          document.getElementById('newDocInput') &&
                          document.getElementById('newDocInput').files.length > 0;

        showOverlay();
        setProgress(0);
        title.textContent = replacing ? 'Saving Replacement File\u2026' : 'Saving Changes\u2026';
        sub.textContent   = replacing
            ? 'Please keep this tab open. Once saved, processing continues in the background.'
            : 'Please wait while your changes are saved.';

        const xhr = new XMLHttpRequest();
        xhr.open('POST', form.action || window.location.href, true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

        xhr.upload.addEventListener('progress', function (e) {
            if (e.lengthComputable) {
                const p = Math.round(e.loaded / e.total * 100);
                setProgress(p);
                if (p >= 100) {
                    title.textContent = 'Saving\u2026';
                    setProgress(100, 'Almost done\u2026');
                }
            }
        });

        xhr.addEventListener('load', function () {
            if (xhr.status >= 200 && xhr.status < 300) {
                try {
                    const res = JSON.parse(xhr.responseText);
                    if (res.success && res.redirectUrl) {
                        title.textContent = 'Saved!';
                        setProgress(100, 'Redirecting\u2026');
                        window.location.href = res.redirectUrl;
                        return;
                    }
                    showErrors(res.errors || [res.message || 'An unexpected error occurred.']);
                } catch (_) {
                    showErrors(['An unexpected error occurred. Please try again.']);
                }
            } else if (xhr.status === 400) {
                try {
                    const res = JSON.parse(xhr.responseText);
                    showErrors(res.errors || [res.message || 'Validation failed.']);
                } catch (_) {
                    showErrors(['Validation failed. Please check all fields.']);
                }
            } else {
                showErrors(['Save failed (HTTP\u00a0' + xhr.status + '). Please try again.']);
            }
        });

        xhr.addEventListener('error', function () {
            showErrors(['Network error. Please check your connection and try again.']);
        });

        xhr.send(data);
    });
}());

    // ── AI Description Assist ────────────────────────────────────────────────
    function toggleAiPanel() {
        const panel = document.getElementById('aiAssistPanel');
        panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
    }

    async function generateDescription(descFieldId, pointersFieldId, nameFieldId, btnId, errId) {
        const pointers = document.getElementById(pointersFieldId)?.value?.trim();
        const errEl    = document.getElementById(errId);
        const btn      = document.getElementById(btnId);
        if (errEl) errEl.textContent = '';

        if (!pointers) {
            if (errEl) errEl.textContent = 'Please enter some key points first.';
            return;
        }

        const processName = document.getElementById(nameFieldId)?.value?.trim() ?? '';

        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Generating…';

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            const resp  = await fetch('/Intake/GenerateDescription', {
                method:  'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ processName, pointers })
            });
            const json = await resp.json();
            if (json.success) {
                document.getElementById(descFieldId).value = json.description;
                document.getElementById('aiAssistPanel').style.display = 'none';
            } else {
                if (errEl) errEl.textContent = json.error ?? 'Generation failed. Please type the description manually.';
            }
        } catch (e) {
            if (errEl) errEl.textContent = 'Network error. Please try again.';
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-stars me-1"></i>Generate Description';
        }
    }
</script>
}

