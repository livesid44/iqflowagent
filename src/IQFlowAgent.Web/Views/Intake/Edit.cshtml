@model IQFlowAgent.Web.ViewModels.EditIntakeViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Intake";
    ViewData["ActivePage"] = "intake";
    var intakeId     = ViewBag.IntakeId     as string ?? "";
    var intakeStatus = ViewBag.IntakeStatus as string ?? "";
}

<style>
    .edit-header {
        display: flex; align-items: center; gap: 16px; margin-bottom: 24px;
    }
    .edit-header-badge {
        background: #fef3c7; color: #92400e;
        border-radius: 20px; padding: 4px 14px; font-size: 0.8rem; font-weight: 600;
    }
    .edit-card {
        background: #fff; border-radius: 12px; padding: 28px 32px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07); margin-bottom: 20px;
    }
    .edit-card h4 {
        font-size: 0.95rem; font-weight: 700; color: #1a2a5e;
        margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid #f0f0f0;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group label { font-size: 0.82rem; font-weight: 600; color: #374151; }
    .form-group input, .form-group select, .form-group textarea {
        border: 1px solid #d1d5db; border-radius: 8px;
        padding: 9px 12px; font-size: 0.87rem; width: 100%; box-sizing: border-box;
        transition: border-color 0.15s;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
        outline: none; border-color: #e31837; box-shadow: 0 0 0 2px rgba(227,24,55,0.1);
    }
    .form-group textarea { resize: vertical; min-height: 90px; }
    .field-error { font-size: 0.78rem; color: #e31837; }
    .full-width { grid-column: 1 / -1; }

    /* Document section */
    .doc-current {
        background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px;
        padding: 12px 16px; margin-bottom: 16px; display: flex; align-items: center; gap: 12px;
    }
    .doc-current-icon {
        width: 36px; height: 36px; background: #16a34a; border-radius: 8px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .doc-current-info { flex: 1; min-width: 0; }
    .doc-current-name { font-size: 0.87rem; font-weight: 600; color: #166534; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .doc-current-meta { font-size: 0.75rem; color: #4ade80; margin-top: 2px; }
    .doc-no-file { color: #9ca3af; font-size: 0.87rem; font-style: italic; margin-bottom: 16px; }
    .doc-upload-zone {
        border: 2px dashed #d1d5db; border-radius: 10px;
        padding: 28px; text-align: center; cursor: pointer;
        transition: all 0.2s; background: #fafafa;
    }
    .doc-upload-zone:hover, .doc-upload-zone.dragover {
        border-color: #e31837; background: #fff5f6;
    }
    .doc-upload-zone input[type=file] { display: none; }
    .doc-upload-selected { font-size: 0.85rem; color: #374151; margin-top: 8px; }

    /* Options section */
    .option-toggle {
        display: flex; align-items: flex-start; gap: 12px;
        padding: 14px 16px; border: 1px solid #e5e7eb; border-radius: 8px;
        margin-bottom: 10px; cursor: pointer; transition: background 0.15s;
    }
    .option-toggle:hover { background: #fafbff; }
    .option-toggle input[type=checkbox] { margin-top: 2px; accent-color: #e31837; }
    .option-toggle-label { flex: 1; }
    .option-toggle-label strong { display: block; font-size: 0.87rem; color: #1a2a5e; }
    .option-toggle-label span { font-size: 0.78rem; color: #6b7280; }
    .option-danger { border-color: #fecaca; background: #fff5f5; }
    .option-danger:hover { background: #fff0f0; }

    /* Actions */
    .edit-actions { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
    .btn-save {
        background: #e31837; color: #fff; border: none; border-radius: 8px;
        padding: 11px 28px; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: background 0.15s;
    }
    .btn-save:hover { background: #c01530; }
    .btn-cancel {
        background: #f1f5f9; color: #374151; border: none; border-radius: 8px;
        padding: 11px 20px; font-size: 0.9rem; font-weight: 600; cursor: pointer; text-decoration: none;
        transition: background 0.15s;
    }
    .btn-cancel:hover { background: #e2e8f0; }
    .edit-warning {
        background: #fffbeb; border: 1px solid #fbbf24; border-radius: 8px;
        padding: 12px 16px; font-size: 0.83rem; color: #92400e; margin-bottom: 20px;
        display: flex; align-items: flex-start; gap: 10px;
    }
</style>

@await Html.PartialAsync("_AppShell")

<main class="app-main">
    <div class="edit-header">
        <div>
            <div class="page-title">Edit Intake</div>
            <div class="page-sub">Update process information for <code>@intakeId</code></div>
        </div>
        <span class="edit-header-badge">@intakeStatus</span>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="edit-warning">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:1px"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><circle cx="12" cy="17" r="1"/></svg>
            @TempData["Error"]
        </div>
    }

    <div class="edit-warning">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Changes are saved immediately. If you upload a new document or enable re-analysis, the AI analysis will re-run in the background.
    </div>

    <form asp-action="Edit" asp-route-id="@ViewContext.RouteData.Values["id"]"
          method="post" enctype="multipart/form-data" novalidate>
        @Html.AntiForgeryToken()

        <!-- Process Information -->
        <div class="edit-card">
            <h4>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a2a5e" stroke-width="2" style="vertical-align:-2px;margin-right:6px"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                Process Information
            </h4>
            <div class="form-row" style="margin-bottom:16px;">
                <div class="form-group">
                    <label asp-for="ProcessName">Process Name *</label>
                    <input asp-for="ProcessName" placeholder="e.g. Invoice Processing" />
                    <span asp-validation-for="ProcessName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ProcessType">Process Type</label>
                    <select asp-for="ProcessType">
                        <option value="Manual">Manual</option>
                        <option value="Semi-Automated">Semi-Automated</option>
                        <option value="Automated">Automated</option>
                    </select>
                </div>
            </div>
            <div class="form-group" style="margin-bottom:16px;">
                <label asp-for="Description">Description *</label>
                <textarea asp-for="Description" placeholder="Describe the process in detail…"></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Priority">Priority</label>
                    <select asp-for="Priority">
                        <option value="High">High</option>
                        <option value="Medium">Medium</option>
                        <option value="Low">Low</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="EstimatedVolumePerDay">Estimated Volume / Day</label>
                    <input asp-for="EstimatedVolumePerDay" type="number" min="0" />
                    <span asp-validation-for="EstimatedVolumePerDay" class="field-error"></span>
                </div>
            </div>
        </div>

        <!-- Ownership -->
        <div class="edit-card">
            <h4>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a2a5e" stroke-width="2" style="vertical-align:-2px;margin-right:6px"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                Ownership
            </h4>
            <div class="form-row" style="margin-bottom:16px;">
                <div class="form-group">
                    <label asp-for="BusinessUnit">Business Unit *</label>
                    <input asp-for="BusinessUnit" placeholder="e.g. Finance" />
                    <span asp-validation-for="BusinessUnit" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Department">Department</label>
                    <input asp-for="Department" placeholder="e.g. Accounts Payable" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ProcessOwnerName">Process Owner Name *</label>
                    <input asp-for="ProcessOwnerName" placeholder="Full name" />
                    <span asp-validation-for="ProcessOwnerName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ProcessOwnerEmail">Process Owner Email *</label>
                    <input asp-for="ProcessOwnerEmail" type="email" placeholder="owner@company.com" />
                    <span asp-validation-for="ProcessOwnerEmail" class="field-error"></span>
                </div>
            </div>
        </div>

        <!-- Location -->
        <div class="edit-card">
            <h4>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a2a5e" stroke-width="2" style="vertical-align:-2px;margin-right:6px"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Location
            </h4>
            <div class="form-row-3" style="margin-bottom:16px;">
                <div class="form-group">
                    <label asp-for="Country">Country *</label>
                    <input asp-for="Country" placeholder="e.g. United States" />
                    <span asp-validation-for="Country" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="City">City</label>
                    <input asp-for="City" placeholder="e.g. New York" />
                </div>
                <div class="form-group">
                    <label asp-for="SiteLocation">Site / Office</label>
                    <input asp-for="SiteLocation" placeholder="e.g. HQ Building A" />
                </div>
            </div>
            <div class="form-group" style="max-width:320px;">
                <label asp-for="TimeZone">Time Zone</label>
                <input asp-for="TimeZone" placeholder="e.g. America/New_York" />
            </div>
        </div>

        <!-- Document -->
        <div class="edit-card">
            <h4>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a2a5e" stroke-width="2" style="vertical-align:-2px;margin-right:6px"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Process Document
            </h4>

            @if (!string.IsNullOrWhiteSpace(Model.CurrentDocumentName))
            {
                <div class="doc-current">
                    <div class="doc-current-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    </div>
                    <div class="doc-current-info">
                        <div class="doc-current-name">@Model.CurrentDocumentName</div>
                        <div class="doc-current-meta">Current document on file</div>
                    </div>
                </div>

                <label class="option-toggle option-danger">
                    <input asp-for="DeleteDocument" type="checkbox" />
                    <div class="option-toggle-label">
                        <strong>Remove existing document</strong>
                        <span>The current document will be permanently deleted. Leave unchecked to keep it.</span>
                    </div>
                </label>
            }
            else
            {
                <div class="doc-no-file">No document currently attached to this intake.</div>
            }

            <!-- Upload zone -->
            <div class="doc-upload-zone" id="dropZone" onclick="document.getElementById('docFile').click()">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" style="margin-bottom:8px"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <div style="font-size:0.85rem;color:#6b7280;">
                    Drop a new document here or <strong style="color:#e31837;">click to browse</strong>
                </div>
                <div style="font-size:0.74rem;color:#9ca3af;margin-top:4px;">PDF, Word, Text, CSV, XML</div>
                <input asp-for="Document" type="file" id="docFile"
                       accept=".pdf,.doc,.docx,.txt,.csv,.xml,.md,.json" />
                <div class="doc-upload-selected" id="selectedFileName"></div>
            </div>
        </div>

        <!-- Options -->
        <div class="edit-card">
            <h4>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a2a5e" stroke-width="2" style="vertical-align:-2px;margin-right:6px"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41"/><path d="M4.93 4.93l1.41 1.41"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/><path d="M4.93 19.07l1.41-1.41"/><path d="M19.07 19.07l-1.41-1.41"/></svg>
                Analysis Options
            </h4>
            <label class="option-toggle">
                <input asp-for="RerunAnalysis" type="checkbox" />
                <div class="option-toggle-label">
                    <strong>Re-run AI Analysis after saving</strong>
                    <span>Triggers a fresh Azure OpenAI analysis. Useful when you update the description or upload a new document. Analysis re-runs automatically if you upload a new document regardless of this setting.</span>
                </div>
            </label>
        </div>

        <!-- Actions -->
        <div class="edit-actions">
            <button type="submit" class="btn-save">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px;margin-right:6px"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Save Changes
            </button>
            <a asp-action="AnalysisResult" asp-route-id="@ViewContext.RouteData.Values["id"]"
               class="btn-cancel">Cancel</a>
        </div>
    </form>
</main>

</div><!-- close app-layout -->

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // File input display
        const docFile = document.getElementById('docFile');
        const label   = document.getElementById('selectedFileName');
        if (docFile) {
            docFile.addEventListener('change', () => {
                label.textContent = docFile.files.length > 0
                    ? '✓ Selected: ' + docFile.files[0].name : '';
            });
        }

        // Drag-drop
        const zone = document.getElementById('dropZone');
        if (zone && docFile) {
            zone.addEventListener('dragover',  e => { e.preventDefault(); zone.classList.add('dragover'); });
            zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
            zone.addEventListener('drop', e => {
                e.preventDefault();
                zone.classList.remove('dragover');
                const dt = new DataTransfer();
                if (e.dataTransfer.files.length > 0) {
                    dt.items.add(e.dataTransfer.files[0]);
                    docFile.files = dt.files;
                    label.textContent = '✓ Selected: ' + e.dataTransfer.files[0].name;
                }
            });
        }
    </script>
}
