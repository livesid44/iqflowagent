@model IQFlowAgent.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Overall Dashboard";
    var search = (string?)ViewBag.SearchFilter ?? "";
    var statusFilter = (string?)ViewBag.StatusFilter ?? "";
    var buFilter     = (string?)ViewBag.BusinessUnitFilter ?? "";
    var countryFilter = (string?)ViewBag.CountryFilter ?? "";
    var allStatuses   = ViewBag.AllStatuses       as List<string> ?? new List<string>();
    var allBUs        = ViewBag.AllBusinessUnits  as List<string> ?? new List<string>();
    var allCountries  = ViewBag.AllCountries      as List<string> ?? new List<string>();

    // Colour helpers
    string IntakeStatusClass(string s) => s switch {
        "Closed"    => "badge-closed",
        "Complete"  => "badge-complete",
        "Analyzing" => "badge-analyzing",
        "Submitted" => "badge-submitted",
        "Error"     => "badge-error",
        _           => "badge-draft"
    };
    string PriorityClass(string p) => p switch {
        "High"   => "pri-high",
        "Medium" => "pri-med",
        _        => "pri-low"
    };
    string TaskBarColor(int pct) => pct >= 100 ? "#28a745" : pct >= 50 ? "#fd7e14" : "#e31837";
}

@await Html.PartialAsync("_AppShell", new ViewDataDictionary(ViewData) { { "ActivePage", "dashboard" } })

<main class="app-main">

<style>
/* ── KPI cards ───────────────────────────────────────────────────────── */
.kpi-section { margin-bottom: 28px; }
.kpi-section-title { font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1px; color: #888; margin-bottom: 10px; }
.kpi-grid { display: grid; gap: 16px; }
.kpi-grid-intakes { grid-template-columns: repeat(5, 1fr); }
.kpi-grid-tasks   { grid-template-columns: repeat(5, 1fr); }
@@media (max-width: 1100px) {
    .kpi-grid-intakes, .kpi-grid-tasks { grid-template-columns: repeat(3, 1fr); }
}
@@media (max-width: 700px) {
    .kpi-grid-intakes, .kpi-grid-tasks { grid-template-columns: repeat(2, 1fr); }
}
.kpi-card {
    background: #fff; border-radius: 10px; padding: 18px 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    display: flex; align-items: center; gap: 16px;
}
.kpi-icon {
    width: 48px; height: 48px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; flex-shrink: 0;
}
.kpi-icon-blue   { background: #e8f0fe; color: #1a73e8; }
.kpi-icon-green  { background: #e6f4ea; color: #28a745; }
.kpi-icon-red    { background: #fde8ea; color: #e31837; }
.kpi-icon-amber  { background: #fff3cd; color: #e6a817; }
.kpi-icon-purple { background: #f0e8fe; color: #7b2fff; }
.kpi-icon-teal   { background: #e0f5f5; color: #0d9488; }
.kpi-icon-grey   { background: #f0f0f0; color: #666; }
.kpi-body { flex: 1; min-width: 0; }
.kpi-value { font-size: 1.9rem; font-weight: 700; color: #1a2a5e; line-height: 1; }
.kpi-label { font-size: 0.78rem; color: #777; margin-top: 4px; }

/* ── Filter bar ─────────────────────────────────────────────────────── */
.filter-bar {
    background: #fff; border-radius: 10px; padding: 14px 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07); margin-bottom: 20px;
    display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
}
.filter-bar input, .filter-bar select {
    border: 1px solid #ddd; border-radius: 6px; padding: 7px 12px;
    font-size: 0.85rem; color: #333; background: #fafafa;
}
.filter-bar input { min-width: 220px; }
.filter-bar select { min-width: 150px; }
.btn-filter {
    background: #1a2a5e; color: #fff; border: none;
    border-radius: 6px; padding: 7px 18px; font-size: 0.85rem; cursor: pointer;
}
.btn-filter:hover { background: #142050; }
.btn-clear {
    background: #f0f0f0; color: #555; border: none;
    border-radius: 6px; padding: 7px 14px; font-size: 0.85rem; cursor: pointer;
    text-decoration: none; display: inline-block; line-height: 1.4;
}
.btn-clear:hover { background: #e0e0e0; color: #333; }
.filter-results { font-size: 0.82rem; color: #888; margin-left: auto; white-space: nowrap; }

/* ── Intake breakdown table ─────────────────────────────────────────── */
.breakdown-card {
    background: #fff; border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07); overflow: hidden;
}
.breakdown-header {
    padding: 16px 20px; border-bottom: 1px solid #f0f0f0;
    display: flex; align-items: center; justify-content: space-between;
}
.breakdown-header h2 { font-size: 1rem; font-weight: 700; color: #1a2a5e; margin: 0; }
.breakdown-header .row-count {
    font-size: 0.8rem; color: #888; background: #f5f5f5;
    padding: 3px 10px; border-radius: 20px;
}
.bd-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.bd-table th {
    background: #f8f9fa; color: #555; font-weight: 600;
    padding: 11px 14px; text-align: left; border-bottom: 2px solid #e9ecef;
    white-space: nowrap;
}
.bd-table td {
    padding: 11px 14px; border-bottom: 1px solid #f0f0f0;
    vertical-align: middle;
}
.bd-table tr:last-child td { border-bottom: none; }
.bd-table tr:hover td { background: #fafbff; }

/* Intake status badges */
.badge-status {
    display: inline-block; padding: 3px 9px; border-radius: 20px;
    font-size: 0.75rem; font-weight: 600; white-space: nowrap;
}
.badge-closed    { background: #e6f4ea; color: #28a745; }
.badge-complete  { background: #e8f0fe; color: #1a73e8; }
.badge-analyzing { background: #fff3cd; color: #e6a817; }
.badge-submitted { background: #f0e8fe; color: #7b2fff; }
.badge-error     { background: #fde8ea; color: #e31837; }
.badge-draft     { background: #f0f0f0; color: #888; }

/* Priority pills */
.pri-tag { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
.pri-high { background: #fde8ea; color: #e31837; }
.pri-med  { background: #fff3cd; color: #e6a817; }
.pri-low  { background: #e6f4ea; color: #28a745; }

/* Task count chips */
.task-chip {
    display: inline-block; min-width: 28px; text-align: center;
    padding: 2px 7px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;
}
.chip-open      { background: #fde8ea; color: #e31837; }
.chip-inprog    { background: #fff3cd; color: #e6a817; }
.chip-completed { background: #e6f4ea; color: #28a745; }
.chip-cancelled { background: #f0f0f0; color: #888; }
.chip-total     { background: #e8f0fe; color: #1a73e8; }

/* Progress bar */
.prog-wrap { min-width: 90px; }
.prog-bar-bg {
    background: #eee; border-radius: 4px; height: 8px; overflow: hidden; width: 100%;
}
.prog-bar-fill { height: 8px; border-radius: 4px; transition: width 0.4s; }
.prog-pct { font-size: 0.72rem; color: #666; margin-top: 3px; }

/* Actions */
.action-link {
    font-size: 0.8rem; color: #1a73e8; text-decoration: none; margin-right: 8px; white-space: nowrap;
}
.action-link:hover { color: #0d47a1; text-decoration: underline; }

/* Empty state */
.empty-state { text-align: center; padding: 48px 20px; color: #aaa; }
.empty-state .bi { font-size: 2.5rem; display: block; margin-bottom: 12px; }

/* Report badge */
.report-badge {
    display: inline-block; font-size: 0.7rem; padding: 2px 7px;
    border-radius: 10px; background: #e6f4ea; color: #28a745; font-weight: 600;
}
</style>

<!-- Page title -->
<div class="page-title">Overall Dashboard</div>
<div class="page-sub">Global view of all intakes, tasks and completion status</div>

<!-- ── INTAKE KPIs ─────────────────────────────────────────────────── -->
<div class="kpi-section">
    <div class="kpi-section-title">Intakes Overview</div>
    <div class="kpi-grid kpi-grid-intakes">
        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-blue"><i class="bi bi-inbox-fill"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@Model.TotalIntakes</div>
                <div class="kpi-label">Total Intakes</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-purple"><i class="bi bi-activity"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@Model.ActiveIntakes</div>
                <div class="kpi-label">Active</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-grey"><i class="bi bi-pencil-square"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@Model.DraftIntakes</div>
                <div class="kpi-label">Draft</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-green"><i class="bi bi-check-circle-fill"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@Model.ClosedIntakes</div>
                <div class="kpi-label">Closed</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-red"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@Model.ErrorIntakes</div>
                <div class="kpi-label">Error</div>
            </div>
        </div>
    </div>
</div>

<!-- ── TASK KPIs ──────────────────────────────────────────────────── -->
<div class="kpi-section">
    <div class="kpi-section-title">Tasks Overview (All Intakes)</div>
    <div class="kpi-grid kpi-grid-tasks">
        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-blue"><i class="bi bi-list-task"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@Model.TotalTasks</div>
                <div class="kpi-label">Total Tasks</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-red"><i class="bi bi-circle-fill"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@Model.OpenTasks</div>
                <div class="kpi-label">Open</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-amber"><i class="bi bi-arrow-repeat"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@Model.InProgressTasks</div>
                <div class="kpi-label">In Progress</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-green"><i class="bi bi-check2-all"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@Model.CompletedTasks</div>
                <div class="kpi-label">Completed</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-grey"><i class="bi bi-slash-circle"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@Model.CancelledTasks</div>
                <div class="kpi-label">Cancelled</div>
            </div>
        </div>
    </div>
</div>

<!-- ── FILTER BAR ─────────────────────────────────────────────────── -->
<form method="get" action="/Dashboard">
    <div class="filter-bar">
        <input type="text" name="search" placeholder="Search Intake ID / Process / BU…"
               value="@search" />
        <select name="status">
            <option value="">All Statuses</option>
            @foreach (var s in allStatuses)
            {
                <option value="@s" selected="@(s == statusFilter ? "selected" : null)">@s</option>
            }
        </select>
        <select name="businessUnit">
            <option value="">All Business Units</option>
            @foreach (var bu in allBUs)
            {
                <option value="@bu" selected="@(bu == buFilter ? "selected" : null)">@bu</option>
            }
        </select>
        <select name="country">
            <option value="">All Countries</option>
            @foreach (var c in allCountries)
            {
                <option value="@c" selected="@(c == countryFilter ? "selected" : null)">@c</option>
            }
        </select>
        <button type="submit" class="btn-filter"><i class="bi bi-funnel-fill me-1"></i>Filter</button>
        <a href="/Dashboard" class="btn-clear"><i class="bi bi-x-circle me-1"></i>Clear</a>
        <span class="filter-results">Showing @Model.IntakeRows.Count intake(s)</span>
    </div>
</form>

<!-- ── PER-INTAKE BREAKDOWN TABLE ─────────────────────────────────── -->
<div class="breakdown-card">
    <div class="breakdown-header">
        <h2><i class="bi bi-table me-2"></i>Intake Task Breakdown</h2>
        <span class="row-count">@Model.IntakeRows.Count row(s)</span>
    </div>

    @if (!Model.IntakeRows.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <p>No intakes found. <a asp-controller="Intake" asp-action="Chat">Submit your first intake</a></p>
        </div>
    }
    else
    {
        <div style="overflow-x:auto;">
        <table class="bd-table">
            <thead>
                <tr>
                    <th>Intake ID</th>
                    <th>Process Name</th>
                    <th>Business Unit</th>
                    <th>Country</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th style="text-align:center;">Total</th>
                    <th style="text-align:center;">Open</th>
                    <th style="text-align:center;">In&nbsp;Progress</th>
                    <th style="text-align:center;">Completed</th>
                    <th style="text-align:center;">Cancelled</th>
                    <th>Progress</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.IntakeRows)
            {
                var barColor = TaskBarColor(row.ProgressPercent);
                <tr>
                    <td>
                        <strong style="font-family:monospace;color:#1a2a5e;">@row.IntakeId</strong>
                        @if (row.HasFinalReport)
                        {
                            <span class="report-badge ms-1" title="Final report generated">📄 Report</span>
                        }
                    </td>
                    <td style="max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                        title="@row.ProcessName">@row.ProcessName</td>
                    <td>@row.BusinessUnit</td>
                    <td>@row.Country</td>
                    <td><span class="pri-tag @PriorityClass(row.Priority)">@row.Priority</span></td>
                    <td><span class="badge-status @IntakeStatusClass(row.Status)">@row.Status</span></td>
                    <td style="white-space:nowrap; color:#888; font-size:0.8rem;">
                        @row.CreatedAt.ToString("dd MMM yyyy")
                    </td>
                    <td style="text-align:center;">
                        <span class="task-chip chip-total">@row.TotalTasks</span>
                    </td>
                    <td style="text-align:center;">
                        @if (row.OpenTasks > 0)
                        {
                            <span class="task-chip chip-open">@row.OpenTasks</span>
                        }
                        else { <span style="color:#ccc;">—</span> }
                    </td>
                    <td style="text-align:center;">
                        @if (row.InProgressTasks > 0)
                        {
                            <span class="task-chip chip-inprog">@row.InProgressTasks</span>
                        }
                        else { <span style="color:#ccc;">—</span> }
                    </td>
                    <td style="text-align:center;">
                        @if (row.CompletedTasks > 0)
                        {
                            <span class="task-chip chip-completed">@row.CompletedTasks</span>
                        }
                        else { <span style="color:#ccc;">—</span> }
                    </td>
                    <td style="text-align:center;">
                        @if (row.CancelledTasks > 0)
                        {
                            <span class="task-chip chip-cancelled">@row.CancelledTasks</span>
                        }
                        else { <span style="color:#ccc;">—</span> }
                    </td>
                    <td>
                        <div class="prog-wrap">
                            <div class="prog-bar-bg">
                                <div class="prog-bar-fill"
                                     style="width:@row.ProgressPercent%; background:@barColor;">
                                </div>
                            </div>
                            <div class="prog-pct">@row.ProgressPercent% closed</div>
                        </div>
                    </td>
                    <td style="white-space:nowrap;">
                        <a asp-controller="Analysis" asp-action="Index"
                           asp-route-selectedId="@row.Id" class="action-link"
                           title="View AI Analysis"><i class="bi bi-robot"></i> Analysis</a>
                        <a asp-controller="Task" asp-action="Index"
                           asp-route-selectedId="@row.Id" class="action-link"
                           title="View Tasks"><i class="bi bi-kanban"></i> Tasks</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }
</div>

</main>
