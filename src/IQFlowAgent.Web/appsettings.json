{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SqlServer": "Server=YOUR_SQL_SERVER;Database=IQFlowAgent;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;",
    "Sqlite": "Data Source=App_Data/iqflowagent.db"
  },
  "AzureOpenAI": {
    "Endpoint": "https://YOUR_RESOURCE.cognitiveservices.azure.com/",
    "ApiKey": "YOUR_API_KEY",
    "DeploymentName": "YOUR_DEPLOYMENT_NAME",
    "ApiVersion": "2025-01-01-preview",
    "MaxTokens": "2000"
  },
  "AzureStorage": {
    "ConnectionString": "YOUR_STORAGE_CONNECTION_STRING",
    "ContainerName": "intakes"
  },
  "AzureDocumentIntelligence": {
    "Endpoint": "https://YOUR_DI_RESOURCE.cognitiveservices.azure.com/",
    "ApiKey": "YOUR_DI_API_KEY"
  }
}
